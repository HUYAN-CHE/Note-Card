.home-page {
  padding-top: 24rpx;
}

.home-hero {
  position: relative;
  height: 382rpx;
  margin: 0 0 18rpx;
}

.hero-card {
  position: absolute;
  left: 50%;
  width: 430rpx;
  min-height: 286rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: 0 34rpx 80rpx rgba(69, 118, 110, 0.18);
}

.hero-card-back {
  top: 46rpx;
  transform: translateX(-50%) rotate(8deg);
  padding: 54rpx 40rpx;
  background: rgba(255, 255, 255, 0.42);
}

.hero-card-front {
  top: 14rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 306rpx;
  padding: 36rpx;
  transform: translateX(-50%) rotate(-3deg);
}

.hero-line {
  width: 100%;
  height: 24rpx;
  margin-bottom: 28rpx;
  border-radius: 999rpx;
  background: rgba(37, 62, 52, 0.1);
}

.hero-line.short {
  width: 42%;
}

.hero-line.tiny {
  width: 68%;
}

.hero-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #62d3e5;
  color: #102423;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 34rpx rgba(98, 211, 229, 0.34);
}

.hero-title {
  margin-top: 30rpx;
  color: #111b18;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.14;
}

.hero-desc {
  margin-top: 14rpx;
  color: #60756f;
  font-size: 24rpx;
}

.hero-dots {
  display: flex;
  gap: 12rpx;
  margin-top: 28rpx;
}

.hero-dots text {
  width: 48rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #e8f1ee;
}

.hero-dots text:first-child {
  width: 76rpx;
  background: #bdeff1;
}

.hero-action {
  width: 520rpx;
  margin: -34rpx auto 0;
}

.ai-hint {
  margin-top: 22rpx;
  border-color: rgba(216, 200, 137, 0.5);
  background: rgba(255, 246, 220, 0.74);
}

.hint-button {
  margin-top: 18rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.quick-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 166rpx;
  padding: 24rpx;
  text-align: left;
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #e8fbfb;
  color: #203824;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.quick-title {
  margin-top: 22rpx;
  font-size: 30rpx;
  font-weight: 650;
}

.quick-desc {
  margin-top: 6rpx;
  color: #68705f;
  font-size: 24rpx;
}

.today-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.today-number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: #101816;
  color: #f7f2e8;
  font-size: 42rpx;
  font-weight: 700;
}

.row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.row .item-title {
  flex: 1;
}

.summary {
  margin-top: 16rpx;
  color: #3a4736;
  font-size: 26rpx;
  line-height: 1.45;
}
