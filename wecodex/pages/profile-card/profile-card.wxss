.profile-hero {
  position: relative;
  overflow: hidden;
  padding: 54rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 16rpx;
  background: linear-gradient(155deg, #101816 0%, #1e6d5b 55%, #67d8e6 100%);
  color: #f7f2e8;
  text-align: center;
  box-shadow: 0 28rpx 70rpx rgba(24, 95, 86, 0.2);
}

.profile-hero::after {
  content: "";
  position: absolute;
  right: -54rpx;
  top: 78rpx;
  width: 226rpx;
  height: 164rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.16);
  transform: rotate(12deg);
}

.profile-logo {
  width: 112rpx;
  height: 112rpx;
  margin-bottom: 24rpx;
  border-radius: 26rpx;
  box-shadow: 0 20rpx 44rpx rgba(0, 0, 0, 0.18);
}

.profile-name {
  font-size: 42rpx;
  font-weight: 700;
}

.profile-role {
  margin-top: 10rpx;
  color: rgba(248, 240, 221, 0.78);
  font-size: 26rpx;
}

.profile-desc {
  margin: 22rpx auto 0;
  max-width: 560rpx;
  color: rgba(248, 240, 221, 0.82);
  font-size: 26rpx;
  line-height: 1.5;
}

.service-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.service-pill {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(232, 251, 251, 0.86);
  color: #203824;
  font-size: 24rpx;
}
