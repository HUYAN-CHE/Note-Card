<view class="page pull-demo-page">
  <view class="demo-nav">
    <view class="nav-title">记事卡</view>
    <view class="mini-capsule" aria-hidden="true">
      <text>•••</text>
      <text class="mini-circle"></text>
    </view>
  </view>

  <pull-create-trigger
    bind:trigger="onPullCreate"
    title="生活由无数的小事组成"
    label="下拉新建事项"
    threshold="{{150}}"
    max-drag="{{188}}"
  >
    <view class="sheet-head">
      <view>
        <view class="sheet-title">最近记事卡</view>
        <view class="sheet-subtitle">打开临近消息提醒</view>
      </view>
      <switch class="sheet-switch" checked color="#24c86a" />
    </view>

    <view class="task-card" bindtap="openLatestCard" data-action="open_recent_card" aria-label="打开最近记事卡 官网改版">
      <view class="task-icon" aria-hidden="true">
        <text class="task-icon-shape"></text>
      </view>
      <view class="task-main">
        <view class="task-row">
          <view class="task-title">官网改版</view>
          <text class="task-tag">待确认</text>
        </view>
        <view class="task-meta">截止日期 10:00 AM</view>
      </view>
    </view>

    <view class="floating-tabs" aria-hidden="true">
      <view class="tab-item active">☰ 事项</view>
      <view class="tab-item">○ 服务</view>
    </view>
  </pull-create-trigger>
</view>
