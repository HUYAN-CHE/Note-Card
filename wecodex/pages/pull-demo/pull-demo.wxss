.pull-demo-page {
  min-height: 100vh;
  padding: 0;
  overflow: hidden;
  background: #bdf5b8;
}

.demo-nav {
  position: relative;
  z-index: 2;
  height: 132rpx;
  padding: 58rpx 34rpx 0;
  background: #bdf5b8;
}

.nav-title {
  color: #142115;
  font-size: 28rpx;
  font-weight: 750;
}

.mini-capsule {
  position: absolute;
  top: 52rpx;
  right: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 22rpx;
  width: 172rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #101816;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: inset 0 0 0 1rpx rgba(18, 24, 21, 0.08);
}

.mini-circle {
  width: 30rpx;
  height: 30rpx;
  border: 6rpx solid #101816;
  border-radius: 50%;
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.sheet-title {
  color: #111816;
  font-size: 34rpx;
  font-weight: 800;
}

.sheet-subtitle {
  margin-top: 10rpx;
  color: #9aa19c;
  font-size: 26rpx;
}

.sheet-switch {
  transform: scale(0.84);
  transform-origin: right top;
}

.task-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-top: 42rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  background: #f8f9fb;
  box-shadow: 0 18rpx 46rpx rgba(24, 32, 27, 0.06);
}

.task-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: #fff;
  flex: 0 0 78rpx;
}

.task-icon-shape {
  width: 42rpx;
  height: 42rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #ffefe5 0%, #ff9c68 48%, #24c86a 49%, #24c86a 100%);
  transform: rotate(-32deg);
  box-shadow: 0 6rpx 14rpx rgba(255, 135, 96, 0.2);
}

.task-main {
  min-width: 0;
  flex: 1;
}

.task-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.task-title {
  color: #111816;
  font-size: 34rpx;
  font-weight: 800;
}

.task-tag {
  min-width: 116rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(17, 24, 22, 0.08);
  border-radius: 999rpx;
  background: #fff;
  color: #68706a;
  font-size: 24rpx;
  text-align: center;
}

.task-meta {
  margin-top: 10rpx;
  color: #a0a5a1;
  font-size: 26rpx;
}

.floating-tabs {
  position: fixed;
  left: 50%;
  bottom: calc(38rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1fr 1fr;
  width: 520rpx;
  padding: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 22rpx 64rpx rgba(22, 32, 25, 0.14);
  transform: translateX(-50%);
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  border-radius: 999rpx;
  color: #7f8782;
  font-size: 28rpx;
  font-weight: 700;
}

.tab-item.active {
  background: #d9ffe8;
  color: #057c47;
}
