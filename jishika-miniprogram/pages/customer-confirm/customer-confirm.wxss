.confirm-title {
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.25;
  text-align: center;
}

.confirm-summary {
  margin-top: 20rpx;
  color: #3a4736;
  font-size: 28rpx;
  line-height: 1.55;
  text-align: center;
}

.block-title {
  margin: 24rpx 0 14rpx;
  color: #485541;
  font-size: 24rpx;
  font-weight: 650;
}

.questions-title {
  margin-top: 30rpx;
}

.check-line,
.question-line {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.52);
  color: #162116;
  font-size: 28rpx;
  line-height: 1.45;
}

.check-dot,
.question-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-top: 4rpx;
  border-radius: 50%;
  flex: 0 0 34rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.check-dot {
  background: #b8edf1;
  color: #203824;
}

.question-dot {
  background: #fff0c8;
  color: #714b20;
}

.supplement-field {
  margin-top: 28rpx;
}

.compact {
  min-height: 156rpx;
}

.button-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
