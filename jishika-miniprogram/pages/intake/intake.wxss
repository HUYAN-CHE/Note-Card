.intake-page {
  padding-top: 0;
  overflow-x: hidden;
}

.custom-nav {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 28rpx;
  background: transparent;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-left: -12rpx;
  flex-shrink: 0;
}

.nav-back-icon {
  color: #162116;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
}

.nav-title-wrap {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.nav-title {
  color: #162116;
  font-size: 32rpx;
  font-weight: 700;
}

.intro-card {
  position: relative;
  overflow: hidden;
  min-height: 286rpx;
  padding: 38rpx;
  background: linear-gradient(155deg, rgba(64, 206, 167, 0.88), rgba(117, 218, 239, 0.7));
  color: #ffffff;
}

.intro-card::after {
  content: "";
  position: absolute;
  right: -42rpx;
  bottom: -48rpx;
  width: 258rpx;
  height: 184rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.24);
  transform: rotate(-10deg);
}

.intro-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.24);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.intro-title {
  position: relative;
  margin-top: 34rpx;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.04;
  z-index: 1;
}

.intro-title.second {
  margin-top: 4rpx;
}

.intro-subtitle {
  position: relative;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  z-index: 1;
}

.type-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.type-tab {
  min-height: 78rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  color: #3a4736;
  font-size: 26rpx;
  font-weight: 600;
}

.type-tab.active {
  background: #101816;
  color: #f7f2e8;
}

.input-card {
  margin-top: 22rpx;
  overflow: hidden;
}

.input-card .textarea {
  min-height: 184rpx;
}

.input-card .button-row {
  display: flex;
  gap: 16rpx;
}

.input-card .ghost-button {
  flex: 1;
  min-width: 0;
}

.generate-action {
  width: 440rpx;
  min-height: 104rpx;
  margin-left: auto;
  margin-right: auto;
}

.file-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.file-pill {
  max-width: 100%;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(232, 251, 251, 0.92);
  color: #34452f;
  font-size: 22rpx;
}

.privacy {
  background: rgba(255, 246, 220, 0.74);
  margin-bottom: env(safe-area-inset-bottom);
}
