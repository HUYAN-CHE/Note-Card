<view class="page intake-page">
  <!-- 顶部说明 -->
  <view class="intake-header">
    <view class="intake-mark">AI</view>
    <view class="intake-title">把聊天说的事</view>
    <view class="intake-title">整理成记事卡</view>
    <view class="intake-subtitle">先生成草稿，再编辑确认</view>
  </view>

  <!-- 类型选择 -->
  <view class="type-section">
    <view class="section-label">选择类型</view>
    <view class="type-grid">
      <view
        wx:for="{{types}}"
        wx:key="value"
        class="type-pill {{selectedType === item.value ? 'active' : ''}}"
        bindtap="selectType"
        data-type="{{item.value}}"
      >{{item.label}}</view>
    </view>
  </view>

  <!-- 聊天内容输入 -->
  <view class="input-card">
    <view class="section-label">聊天内容</view>
    <textarea
      class="intake-textarea"
      value="{{contextText}}"
      placeholder="把客户私聊、群聊摘要或语音整理结果粘贴到这里"
      bindinput="onTextInput"
      maxlength="4000"
    />
    <view class="input-actions">
      <view class="input-action" bindtap="useClipboard">粘贴</view>
      <view class="input-action" bindtap="chooseScreenshot">截图</view>
    </view>
    <view class="file-list" wx:if="{{files.length}}">
      <view wx:for="{{files}}" wx:key="path" class="file-pill">{{item.name || '聊天截图'}}</view>
    </view>
  </view>

  <!-- 生成草稿 -->
  <view class="generate-wrap">
    <view class="generate-btn" bindtap="generateDraft">
      <view class="generate-text">
        <text class="generate-title">生成草稿</text>
        <text class="generate-desc">先整理，再编辑确认</text>
      </view>
      <view class="generate-arrow">→</view>
    </view>
  </view>

  <!-- 隐私说明 -->
  <view class="privacy-card">
    <view class="privacy-title">🔒 隐私处理</view>
    <view class="privacy-desc">第一版仅保存整理后的记事卡。原始聊天上下文可在后续版本设置自动清理周期。</view>
  </view>
</view>
