<view class="page intake-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-back" bindtap="goBack" aria-label="返回">
      <text class="nav-back-icon">‹</text>
    </view>
    <text class="nav-title">从聊天整理</text>
  </view>

  <view class="intro-card card panel">
    <view class="intro-mark" aria-hidden="true">AI</view>
    <view class="intro-title">这段聊天</view>
    <view class="intro-title second">记成卡</view>
    <view class="intro-subtitle">先生成草稿，再由商家确认</view>
  </view>

  <view class="type-tabs">
    <button wx:for="{{types}}" wx:key="value" class="type-tab {{selectedType === item.value ? 'active' : ''}}" bindtap="selectType" data-type="{{item.value}}" data-action="select_card_type" aria-label="选择整理类型 {{item.label}}">
      {{item.label}}
    </button>
  </view>

  <view class="card panel section input-card">
    <view class="field">
      <text class="label">聊天内容</text>
      <textarea class="textarea" value="{{contextText}}" placeholder="把客户私聊、群聊摘要或语音整理结果粘贴到这里" bindinput="onTextInput" maxlength="4000" data-field="contextText" aria-label="聊天内容输入框" />
    </view>

    <view class="button-row">
      <button class="ghost-button" bindtap="useClipboard" data-action="paste_clipboard" aria-label="粘贴剪贴板聊天内容">粘贴</button>
      <button class="ghost-button" bindtap="chooseScreenshot" data-action="upload_screenshot" aria-label="上传聊天截图">截图</button>
    </view>

    <view wx:if="{{files.length}}" class="file-list">
      <view wx:for="{{files}}" wx:key="path" class="file-pill">{{item.name || '聊天截图'}}</view>
    </view>
  </view>

  <button class="primary-action section generate-action" bindtap="generateDraft" data-action="generate_draft" aria-label="生成记事卡草稿">
    <view>
      <text class="title">生成草稿</text>
      <text class="desc">先整理，再由商家编辑确认</text>
    </view>
    <text class="arrow">→</text>
  </button>

  <view class="privacy card panel section">
    <view class="item-title">隐私处理</view>
    <view class="item-meta">第一版仅保存整理后的记事卡。原始聊天上下文可在后续版本设置自动清理周期。</view>
  </view>
</view>
