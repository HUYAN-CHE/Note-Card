<view class="page card-edit-page">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-back" bindtap="goBack">‹</view>
    <text class="nav-title">新建记事卡</text>
    <view class="nav-save" bindtap="saveAndBack">保存</view>
  </view>

  <!-- 从聊天整理 -->
  <view class="import-trigger" bindtap="toggleImportPanel">
    <text class="import-icon">💬</text>
    <text class="import-title">从聊天整理</text>
    <text class="import-arrow {{showImportPanel ? 'up' : ''}}">›</text>
  </view>

  <view class="import-panel" wx:if="{{showImportPanel}}">
    <view class="field">
      <view class="field-label">聊天内容</view>
      <textarea
        class="field-textarea"
        value="{{importText}}"
        placeholder="把客户私聊、群聊摘要或语音整理结果粘贴到这里"
        bindinput="onImportTextInput"
        maxlength="4000"
      />
      <view class="input-actions">
        <view class="input-action" bindtap="useClipboard">粘贴</view>
        <view class="input-action" bindtap="chooseScreenshot">截图</view>
      </view>
      <view class="file-list" wx:if="{{importFiles.length}}">
        <view wx:for="{{importFiles}}" wx:key="path" class="file-pill">{{item.name || '聊天截图'}}</view>
      </view>
    </view>
    <view class="import-generate" bindtap="generateFromChat">生成草稿</view>
  </view>

  <!-- 标题 -->
  <view class="field">
    <view class="field-label">标题</view>
    <input
      class="field-input"
      value="{{card.projectName}}"
      placeholder="如 品牌官网视觉改版"
      bindinput="onFieldInput"
      data-field="projectName"
    />
  </view>

  <!-- 需求描述 -->
  <view class="field">
    <view class="field-label">需求描述</view>
    <textarea
      class="field-textarea"
      value="{{card.summary}}"
      placeholder="描述一下需要帮忙的事"
      bindinput="onFieldInput"
      data-field="summary"
    />
  </view>

  <!-- 重点 / 待确认 -->
  <view class="field">
    <view class="field-label">
      重点 / 待确认
      <text class="field-hint">用 · 分隔</text>
    </view>
    <input
      class="field-input"
      value="{{keyPointsText}}"
      placeholder="预算 · 风格 · 交期"
      bindinput="onKeyPointsInput"
    />
  </view>

  <!-- 协助者 -->
  <view class="field">
    <view class="field-label">协助者</view>
    <view class="helper-row">
      <view class="helper-avatar" wx:for="{{helpers}}" wx:key="id">
        <text wx:if="{{!item.avatar}}">{{item.initial}}</text>
        <image wx:else src="{{item.avatar}}" mode="aspectFill" />
      </view>
      <view class="helper-add" bindtap="openInviteSheet">＋</view>
    </view>
  </view>

  <!-- 可见性开关 -->
  <view class="toggle-row" bindtap="toggleVisibility">
    <view class="toggle-info">
      <view class="toggle-title">让朋友的朋友也能看到</view>
      <view class="toggle-desc">关闭后仅协助者可见，更私密</view>
    </view>
    <view class="switch {{card.isNetworkVisible ? 'on' : ''}}">
      <view class="switch-knob"></view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="footer">
    <button class="footer-btn ghost" bindtap="saveDraft">存草稿</button>
    <button class="footer-btn primary" bindtap="openInviteSheet">邀请一起用</button>
  </view>

  <!-- 邀请好友底部弹窗 -->
  <view class="sheet-mask" wx:if="{{showInviteSheet}}" bindtap="closeInviteSheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-grab"></view>
      <view class="sheet-title">邀请一起用</view>
      <view class="sheet-sub">选择微信好友或群聊，发送后成为协助者</view>

      <view class="friend-list">
        <view
          class="friend-item"
          wx:for="{{friendCandidates}}"
          wx:key="id"
          bindtap="toggleFriend"
          data-index="{{index}}"
        >
          <view class="friend-avatar">
            <text wx:if="{{!item.avatar}}">{{item.initial}}</text>
            <image wx:else src="{{item.avatar}}" mode="aspectFill" />
          </view>
          <view class="friend-info">
            <text class="friend-name">{{item.nickname}}</text>
            <text class="friend-status">{{item.status}}</text>
          </view>
          <view class="friend-check {{item.selected ? 'on' : ''}}">
            <text wx:if="{{item.selected}}">✓</text>
          </view>
        </view>
      </view>

      <view class="sheet-actions">
        <button class="sheet-btn ghost" bindtap="closeInviteSheet">取消</button>
        <button class="sheet-btn primary" bindtap="sendInvite">发送邀请</button>
      </view>
    </view>
  </view>
</view>
