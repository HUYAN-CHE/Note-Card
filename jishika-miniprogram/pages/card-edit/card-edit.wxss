.card-edit-page {
  min-height: 100vh;
  background: #ffffff;
  padding: 0 32rpx 180rpx;
  box-sizing: border-box;
}

.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  margin: 0 -32rpx 24rpx;
  padding: 0 24rpx;
  background: #ffffff;
}

.nav-back {
  width: 60rpx;
  font-size: 44rpx;
  color: #1a1a1a;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.nav-save {
  font-size: 30rpx;
  color: #00c853;
  font-weight: 700;
}

.field {
  margin-bottom: 32rpx;
}

/* 从聊天整理 */
.import-trigger {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f0fdf4;
  border-radius: 16rpx;
  margin-bottom: 28rpx;
}

.import-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.import-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #00a344;
}

.import-arrow {
  font-size: 36rpx;
  color: #00c853;
  transform: rotate(90deg);
  transition: transform 0.2s ease;
}

.import-arrow.up {
  transform: rotate(-90deg);
}

.import-panel {
  margin-bottom: 28rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.import-generate {
  margin-top: 8rpx;
  padding: 22rpx 0;
  text-align: center;
  background: #00c853;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

.input-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.input-action {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  background: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
  border: 1rpx solid #e8e8e8;
}

.file-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.file-pill {
  max-width: 100%;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e8f5e9;
  color: #00a344;
  font-size: 24rpx;
}

.field-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 14rpx;
}

.field-hint {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

.field-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.field-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 协助者 */
.helper-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.helper-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #00c853, #00a344);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

.helper-avatar image {
  width: 64rpx;
  height: 64rpx;
}

.helper-add {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

/* 可见性开关 */
.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  margin-top: 8rpx;
}

.toggle-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.toggle-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999;
}

.switch {
  position: relative;
  width: 96rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e0e0e0;
  transition: background 0.2s ease;
}

.switch.on {
  background: #00c853;
}

.switch-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.2s ease;
}

.switch.on .switch-knob {
  transform: translateX(40rpx);
}

/* 底部 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.footer-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  text-align: center;
}

.footer-btn::after {
  display: none;
}

.footer-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.footer-btn.primary {
  flex: 1.4;
  color: #fff;
  background: #00c853;
}

/* 底部弹窗 */
.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
}

.sheet-grab {
  width: 64rpx;
  height: 6rpx;
  background: #e0e0e0;
  border-radius: 3rpx;
  margin: 0 auto 24rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
}

.sheet-sub {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.friend-list {
  margin-top: 32rpx;
  max-height: 560rpx;
  overflow-y: auto;
}

.friend-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
}

.friend-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #00c853, #00a344);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.friend-avatar image {
  width: 72rpx;
  height: 72rpx;
}

.friend-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.friend-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.friend-status {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999;
}

.friend-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.friend-check.on {
  background: #00c853;
  border-color: #00c853;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.sheet-btn::after {
  display: none;
}

.sheet-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.sheet-btn.primary {
  color: #fff;
  background: #00c853;
}
