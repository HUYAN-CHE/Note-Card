.my-home-page {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  background: #ffffff;
}

/* 顶部绿色 Hero */
.profile-hero {
  position: relative;
  z-index: 1;
  flex: 0 0 auto;
  width: 100%;
  padding: 28rpx 40rpx 60rpx;
  border-radius: 0 0 48rpx 48rpx;
  background: linear-gradient(180deg, #00c853 0%, #00e676 45%, #1de9b6 100%);
  color: #ffffff;
  box-sizing: border-box;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 32rpx;
}

.edit-btn {
  margin-left: auto;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 24rpx;
  color: #ffffff;
}

.profile-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
}

.avatar-edit {
  padding: 0;
  margin: 0;
  background: rgba(255, 255, 255, 0.25);
  line-height: 1;
}

.avatar-edit::after {
  border: none;
}

.nickname-edit {
  padding: 0;
  margin: 0;
  background: transparent;
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
  text-align: left;
}

.nickname-edit::after {
  border: none;
}

.profile-initial {
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
}

.profile-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.profile-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-name {
  font-size: 44rpx;
  font-weight: 700;
}

.profile-intro {
  font-size: 26rpx;
  opacity: 0.9;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.profile-tag {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 24rpx;
  color: #ffffff;
}

.profile-tags-edit {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tags-input,
.intro-input {
  width: 100%;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  color: #ffffff;
  font-size: 26rpx;
  box-sizing: border-box;
}

.tags-input::placeholder,
.intro-input::placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.intro-input {
  height: 120rpx;
}

.edit-actions {
  display: flex;
  gap: 24rpx;
}

.edit-action {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 28rpx;
}

.edit-action.save {
  background: #ffffff;
  color: #00c853;
  font-weight: 600;
}

.edit-action.cancel {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

/* 内容区 */
.content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  flex: 1;
  width: 100%;
  background: #ffffff;
  overflow: hidden;
  box-sizing: border-box;
}

.tab-header {
  display: flex;
  align-items: center;
  gap: 48rpx;
  padding: 40rpx 48rpx 24rpx;
  border-bottom: 1rpx solid #f0f2f5;
}

.tab-item {
  position: relative;
  font-size: 30rpx;
  font-weight: 400;
  color: #9baaa3;
  padding-bottom: 16rpx;
}

.tab-item.active {
  font-weight: 600;
  color: #162116;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #00c853;
}

.card-scroll {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 32rpx 48rpx;
}

.card-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #f5f7fa;
}

.card-main {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #162116;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-desc {
  font-size: 24rpx;
  color: #6b7a73;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-status {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #00c853;
}

.card-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
}

.card-empty-text {
  font-size: 26rpx;
  color: #9baaa3;
  text-align: center;
}

.content-bottom-space {
  height: calc(120rpx + env(safe-area-inset-bottom));
}
