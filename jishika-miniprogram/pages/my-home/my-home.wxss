.my-home-page {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

/* 顶部资料区 */
.profile-header {
  padding: 120rpx 32rpx 40rpx;
  background: #ffffff;
}

.profile-main {
  display: flex;
  align-items: center;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #f5f7fa;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  margin: 0;
  padding: 0;
  border: 2rpx solid #e8ecef;
  box-sizing: border-box;
}

.profile-avatar::after {
  display: none;
}

.profile-avatar-img {
  width: 128rpx;
  height: 128rpx;
}

.profile-initial {
  font-size: 48rpx;
  font-weight: 700;
  color: #00c853;
}

.profile-info {
  flex: 1;
  margin-left: 28rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
}

.profile-intro {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.edit-btn {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #00c853;
  border: 2rpx solid #00c853;
  border-radius: 32rpx;
  font-weight: 500;
}

/* 编辑表单 */
.avatar-edit {
  background: #f0fdf4 !important;
  border-color: #00c853;
}

.nickname-edit {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  text-align: left;
}

.nickname-edit::after {
  display: none;
}

.profile-edit-form {
  margin-top: 28rpx;
}

.intro-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.edit-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  gap: 20rpx;
}

.edit-action {
  padding: 14rpx 36rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.edit-action.save {
  color: #fff;
  background: #00c853;
}

.edit-action.cancel {
  color: #666;
  background: #f0f0f0;
}

/* 服务能力标签 */
.section {
  margin: 0 32rpx 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.section-action {
  font-size: 26rpx;
  color: #00c853;
  font-weight: 500;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 22rpx;
  background: #f0fdf4;
  border-radius: 28rpx;
}

.tag-text {
  font-size: 26rpx;
  color: #00a344;
}

.tag-remove {
  margin-left: 12rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.tag-empty {
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
}

.tag-edit-area {
  margin-top: 16rpx;
}

.tag-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #333;
}

.candidate-tags {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 14rpx;
}

.candidate-label {
  font-size: 24rpx;
  color: #999;
}

.candidate-tag {
  padding: 8rpx 20rpx;
  background: #f5f7fa;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #00c853;
  border: 1rpx solid #e0f2e9;
}

/* 互助数据 */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 32rpx 40rpx;
  padding: 32rpx 0;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.2;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e0e0e0;
}

/* 内容区 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.tab-header {
  display: flex;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  position: relative;
  padding: 24rpx 0;
  margin-right: 48rpx;
  font-size: 30rpx;
  color: #999;
  font-weight: 500;
}

.tab-item.active {
  color: #1a1a1a;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 4rpx;
  background: #00c853;
  border-radius: 2rpx;
}

.card-scroll {
  flex: 1;
  min-height: 0;
}

.card-list {
  padding: 24rpx 32rpx;
}

.card-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #f5f5f5;
}

.card-main {
  flex: 1;
  min-width: 0;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-status {
  margin-left: 20rpx;
  padding: 8rpx 18rpx;
  font-size: 24rpx;
  color: #00c853;
  background: #f0fdf4;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.card-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
}

.card-empty-text {
  font-size: 28rpx;
  color: #bbb;
}

.content-bottom-space {
  height: 40rpx;
}
