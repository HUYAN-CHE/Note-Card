<view class="page my-home-page">
  <!-- 顶部资料卡 -->
  <view class="profile-card" style="padding-top: {{heroPaddingTop}}rpx;">
    <view class="profile-avatar">
      <text class="profile-initial" wx:if="{{!user.avatar}}">{{user.initial || '我'}}</text>
      <image wx:else class="profile-avatar-img" src="{{user.avatar}}" mode="aspectFill" />
    </view>
    <text class="profile-name">{{user.nickname || '我'}}</text>
    <text class="profile-intro" wx:if="{{user.intro}}">{{user.intro}}</text>
    <view class="profile-edit" bindtap="startEdit">编辑资料</view>
  </view>

  <!-- 编辑资料表单 -->
  <view class="edit-panel" wx:if="{{isEditing}}">
    <button class="edit-avatar" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <text class="profile-initial" wx:if="{{!editForm.avatar}}">{{editForm.initial || '我'}}</text>
      <image wx:else class="profile-avatar-img" src="{{editForm.avatar}}" mode="aspectFill" />
    </button>
    <button class="edit-nickname" open-type="chooseNickname" bind:choosenickname="onChooseNickname">
      {{editForm.nickname || '点击设置昵称'}}
    </button>
    <textarea
      class="edit-intro"
      value="{{editForm.intro}}"
      bindinput="onIntroInput"
      placeholder="一句话介绍"
      maxlength="60"
    />
    <view class="edit-actions">
      <view class="edit-btn save" bindtap="saveProfile">保存</view>
      <view class="edit-btn cancel" bindtap="cancelEdit">取消</view>
    </view>
  </view>

  <view class="divider"></view>

  <!-- 我能提供的服务 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">我能提供的服务</text>
      <text class="section-action" bindtap="toggleTagEdit">{{tagEditing ? '完成' : '＋ 添加'}}</text>
    </view>
    <view class="tag-list" wx:if="{{serviceTags.length}}">
      <view class="tag-pill" wx:for="{{serviceTags}}" wx:key="*this">
        <text class="tag-text">{{item}}</text>
        <text class="tag-remove" wx:if="{{tagEditing}}" bindtap="removeTag" data-index="{{index}}">×</text>
      </view>
    </view>
    <view class="tag-empty" wx:if="{{!serviceTags.length && !tagEditing}}">还没有标签，点击添加</view>

    <view class="tag-edit-area" wx:if="{{tagEditing}}">
      <input
        class="tag-input"
        value="{{tagInput}}"
        bindinput="onTagInput"
        bindconfirm="addTag"
        placeholder="输入标签，按回车添加"
      />
      <view class="candidate-tags" wx:if="{{candidateTags.length}}">
        <text class="candidate-label">推荐：</text>
        <text
          class="candidate-tag"
          wx:for="{{candidateTags}}"
          wx:key="*this"
          bindtap="addCandidateTag"
          data-tag="{{item}}"
        >{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 我的记事卡 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">我的记事卡</text>
    </view>
    <view class="subtabs">
      <view
        class="subtab {{activeTab === 'mine' ? 'on' : ''}}"
        bindtap="switchTab"
        data-tab="mine"
      >未完成 {{counts.mine}}</view>
      <view
        class="subtab {{activeTab === 'done' ? 'on' : ''}}"
        bindtap="switchTab"
        data-tab="done"
      >已完成 {{counts.done}}</view>
      <view
        class="subtab {{activeTab === 'helped' ? 'on' : ''}}"
        bindtap="switchTab"
        data-tab="helped"
      >我协助的 {{counts.helped}}</view>
    </view>

    <scroll-view class="card-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="card-list" wx:if="{{cards.length}}">
        <view
          wx:for="{{cards}}"
          wx:key="id"
          class="ncard"
          bindtap="openCard"
          data-id="{{item.id}}"
        >
          <text class="ncard-title">{{item.title || '未命名事项'}}</text>
          <view class="ncard-meta">
            <view class="status-pill {{item.statusClass}}">
              <view class="dot"></view>
              <text>{{item.statusText}}</text>
            </view>
            <text class="ncard-when">{{item.whenText}}</text>
          </view>
        </view>
      </view>

      <view class="card-empty" wx:if="{{!loading && cards.length === 0}}">
        <text class="card-empty-text">{{emptyText}}</text>
      </view>

      <view class="content-bottom-space"></view>
    </scroll-view>
  </view>

  <!-- 我的互助数据 -->
  <view class="section section-last">
    <view class="section-header">
      <text class="section-title">我的互助数据</text>
    </view>
    <view class="stat-row">
      <view class="stat-item">
        <text class="stat-num">{{stats.helperCount}}</text>
        <text class="stat-label">协作过的人</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.helpedCount}}</text>
        <text class="stat-label">被求助次数</text>
      </view>
    </view>
  </view>
</view>
