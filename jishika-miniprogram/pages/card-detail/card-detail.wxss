.card-detail-page {
  min-height: 100vh;
  background: #ffffff;
  padding: 32rpx 32rpx 160rpx;
  box-sizing: border-box;
}

/* 顶部标题与创立者 */
.detail-hero {
  margin-bottom: 40rpx;
}

.detail-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
}

.creator {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
}

.creator-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #00c853, #00a344);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.creator-avatar image {
  width: 72rpx;
  height: 72rpx;
}

.creator-info {
  display: flex;
  flex-direction: column;
  margin-left: 18rpx;
}

.creator-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.creator-relation {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999;
}

/* 区块 */
.detail-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 18rpx;
}

.detail-summary {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* 协助者 */
.helpers {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.helper {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background: #f8f9fa;
  border-radius: 40rpx;
}

.helper-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #00c853, #00a344);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.helper-avatar image {
  width: 48rpx;
  height: 48rpx;
}

.helper-name {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.helpers-empty {
  font-size: 28rpx;
  color: #999;
}

/* 重点 / 待确认 */
.keypoints {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.keypoint {
  padding: 10rpx 22rpx;
  background: #fff8e6;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #c78000;
}

/* 当前进度 KV */
.kv-list {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
}

.kv-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.kv-item:last-child {
  border-bottom: none;
}

.kv-key {
  font-size: 28rpx;
  color: #888;
}

.kv-value {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.kv-value.doing {
  color: #00c853;
}

.kv-value.todo {
  color: #c78000;
}

.kv-value.done {
  color: #888;
}

.kv-value.muted {
  color: #bbb;
}

/* 底部 */
.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.apply-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #00c853;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.apply-btn::after {
  display: none;
}

/* 底部弹窗 */
.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
}

.sheet-grab {
  width: 64rpx;
  height: 6rpx;
  background: #e0e0e0;
  border-radius: 3rpx;
  margin: 0 auto 24rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
}

.sheet-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  text-align: center;
}

.refer-card {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.refer-emoji {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.refer-text {
  flex: 1;
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
}

.refer-input {
  width: 100%;
  min-height: 120rpx;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.sheet-btn::after {
  display: none;
}

.sheet-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.sheet-btn.primary {
  color: #fff;
  background: #00c853;
}
