/* pages/home/home.wxss */

.home-page {
  position: relative;
  min-height: 100vh;
  padding: 0;
  overflow: hidden;
  background: linear-gradient(180deg, #b8f0b0 0%, #5fc26b 100%);
}

/* Sheet 头部 */
.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.sheet-title-wrap {
  display: flex;
  flex-direction: column;
}

.sheet-title {
  color: #111816;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 42rpx;
}

.sheet-subtitle {
  margin-top: 4rpx;
  color: #9aa19c;
  font-size: 26rpx;
  line-height: 36rpx;
}

.reminder-switch {
  transform: scale(0.84);
  transform-origin: right top;
}

/* 卡片列表 */
.card-list-scroll {
  flex: 1;
  min-height: 0;
  height: 100%;
  margin-top: 34rpx;
}

.create-refresher {
  height: 80px;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #f8f9fb;
  border-radius: 24rpx;
  box-shadow: 0 18rpx 46rpx rgba(24, 32, 27, 0.06);
}

.card-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111816;
  line-height: 44rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-meta {
  font-size: 24rpx;
  color: #a0a5a1;
  line-height: 34rpx;
  margin-top: 8rpx;
}

.card-status {
  flex-shrink: 0;
  padding: 10rpx 22rpx;
  border-radius: 28rpx;
  margin-left: 16rpx;
  background: #fff;
  border: 1rpx solid rgba(17, 24, 22, 0.08);
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #68706a;
}

.status-done {
  background: #dcfce7;
  border-color: transparent;
}

.status-done .status-text {
  color: #16a34a;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
}

.empty-image {
  width: 320rpx;
  height: 320rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 400;
  color: #111816;
  line-height: 42rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #9aa19c;
  line-height: 36rpx;
  margin-top: 4rpx;
  text-align: center;
  padding: 0 60rpx;
}
