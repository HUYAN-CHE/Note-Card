<view class="page home-page">
  <pull-create-trigger
    class="home-pull-trigger"
    bind:trigger="onPullCreate"
    bind:selectDay="selectDay"
    title="生活由无数的小事组成"
    label="下拉新建事项"
    threshold="{{150}}"
    max-drag="{{188}}"
    week-days="{{weekDays}}"
  >
    <view slot="nav" class="home-nav" style="padding-top: {{statusBarHeight}}px;">
      <text class="nav-title">This week</text>
      <view class="nav-capsule">
        <view class="nav-btn" bindtap="onMenuTap" aria-label="菜单">
          <text class="nav-btn-icon menu-icon">···</text>
        </view>
        <view class="nav-btn" bindtap="onProfileTap" aria-label="我的">
          <text class="nav-btn-icon record-icon">◎</text>
        </view>
      </view>
    </view>

    <view class="sheet-head">
      <view class="sheet-title-wrap">
        <text class="sheet-title">最近记事卡</text>
        <text class="sheet-subtitle">打开临近消息提醒</text>
      </view>
      <switch
        class="reminder-switch"
        checked="{{reminderEnabled}}"
        color="#22C55E"
        bindchange="toggleReminder"
        aria-label="打开临近消息提醒"
      />
    </view>

    <scroll-view scroll-y class="card-list-scroll" enhanced show-scrollbar="{{false}}">
      <view wx:if="{{cards.length}}" class="card-list">
        <view
          wx:for="{{cards}}"
          wx:key="id"
          class="card-item"
          bindtap="openCard"
          data-id="{{item.id}}"
          data-action="open_card"
          aria-label="打开记事卡 {{item.projectName || '未命名事项'}}"
        >
          <view class="card-icon">{{item.emoji}}</view>

          <view class="card-info">
            <text class="card-title">{{item.projectName || '未命名事项'}}</text>
            <text class="card-meta">截止日期 {{item.deadlineText}}</text>
          </view>

          <view class="card-status {{item.statusClass}}" aria-hidden="true">
            <text class="status-text">{{item.statusText}}</text>
          </view>
        </view>
      </view>

      <view wx:else class="empty-state">
        <image class="empty-image" src="/assets/images/empty-state-ref.png" mode="aspectFit" aria-hidden="true" />
        <text class="empty-title">还没有记事卡</text>
        <text class="empty-sub">下拉或点击上方按钮，从聊天记录生成一张记事卡</text>
      </view>
    </scroll-view>
  </pull-create-trigger>

  <tab-bar activeTab="home" />
</view>
