<view class="home-page">
  <view class="header">
    <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

    <view class="header-top">
      <text class="section-label">This week</text>
      <view class="header-actions">
        <view class="action-btn" bindtap="onMenuTap" aria-label="菜单">
          <text class="action-icon menu-icon">···</text>
        </view>
        <view class="action-btn" bindtap="onProfileTap" aria-label="我的">
          <text class="action-icon record-icon">◎</text>
        </view>
      </view>
    </view>

    <view class="date-picker">
      <view class="date-list">
        <view
          wx:for="{{calendarDays}}"
          wx:for-item="day"
          wx:key="date"
          class="day-item {{selectedIndex === index ? 'selected' : ''}} {{day.isToday ? 'today' : ''}}"
          bindtap="selectDay"
          data-date="{{day.date}}"
          data-index="{{index}}"
        >
          <view class="day-inner">
            <text class="day-week">{{day.week}}</text>
            <text class="day-number">{{day.day}}</text>
            <view wx:if="{{selectedIndex === index}}" class="day-dot"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="header-body">
      <text class="slogan">生活由无数的小事组成</text>
      <view class="cta-pill" bindtap="goIntake" data-action="create_from_chat" aria-label="新建事项">
        <text class="cta-plus">+</text>
        <text class="cta-text">下拉新建事项</text>
      </view>
    </view>
  </view>

  <view class="bottom-sheet" style="top: {{sheetTopPercent}}vh;">
    <view class="sheet-header">
      <view class="sheet-drag-handle" aria-hidden="true"></view>
      <view class="sheet-header-content">
        <view class="sheet-title-wrap">
          <text class="sheet-title">最近记事卡</text>
          <text class="sheet-subtitle">打开临近消息提醒</text>
        </view>
        <switch class="reminder-switch" checked="{{reminderEnabled}}" color="#22C55E" bindchange="toggleReminder" aria-label="打开临近消息提醒" />
      </view>
    </view>

    <scroll-view scroll-y class="card-list-scroll" enhanced show-scrollbar="{{false}}">
      <view wx:if="{{cards.length}}" class="card-list">
        <view
          wx:for="{{cards}}"
          wx:key="id"
          class="card-item"
          bindtap="openCard"
          data-id="{{item.id}}"
          data-action="open_card"
          aria-label="打开记事卡 {{item.projectName || '未命名事项'}}"
        >
          <view class="card-icon">{{item.emoji}}</view>

          <view class="card-info">
            <text class="card-title">{{item.projectName || '未命名事项'}}</text>
            <text class="card-meta">截止日期 {{item.deadlineText}}</text>
          </view>

          <view class="card-status {{item.statusClass}}" aria-hidden="true">
            <text class="status-text">{{item.statusText}}</text>
          </view>
        </view>
      </view>

      <view wx:else class="empty-state">
        <image class="empty-image" src="/assets/images/empty-state-ref.png" mode="aspectFit" aria-hidden="true" />
        <text class="empty-title">还没有记事卡</text>
        <text class="empty-sub">下拉或点击上方按钮，从聊天记录生成一张记事卡</text>
      </view>
    </scroll-view>
  </view>

  <tab-bar activeTab="home" />
</view>
