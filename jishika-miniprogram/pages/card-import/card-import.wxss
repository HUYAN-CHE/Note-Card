.card-import-page {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 120rpx;
}

.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.nav-back {
  font-size: 40rpx;
  color: #333;
  width: 80rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.nav-action {
  font-size: 28rpx;
  color: #22c55e;
  font-weight: 600;
  width: 80rpx;
  text-align: right;
}

.src-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin: 24rpx;
  padding: 10rpx 20rpx;
  background: #dcfce7;
  color: #166534;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 999rpx;
}

.type-section {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 24rpx;
}

.section-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-item {
  padding: 14rpx 24rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 26rpx;
  border-radius: 999rpx;
  border: 2rpx solid transparent;
}

.type-item.active {
  background: #dcfce7;
  color: #166534;
  border-color: #22c55e;
}

.field {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 24rpx;
}

.field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.field-textarea,
.imp-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.input-action {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 26rpx;
  border-radius: 12rpx;
}

.file-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.file-pill {
  padding: 8rpx 16rpx;
  background: #e0f2fe;
  color: #0369a1;
  font-size: 24rpx;
  border-radius: 999rpx;
}

.preview-section {
  margin: 0 24rpx;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.preview-regen {
  font-size: 26rpx;
  color: #22c55e;
}

.imp-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid #e5e7eb;
}

.imp-card.off {
  opacity: 0.45;
}

.imp-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 4rpx solid #d1d5db;
  display: grid;
  place-items: center;
  color: transparent;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.imp-check.on {
  background: #22c55e;
  border-color: #22c55e;
  color: #fff;
}

.imp-body {
  flex: 1;
  min-width: 0;
}

.imp-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #166534;
  margin-bottom: 12rpx;
}

.imp-ai {
  font-size: 20rpx;
  background: #dcfce7;
  color: #166534;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  margin-left: 8rpx;
}

.imp-input,
.imp-textarea {
  width: 100%;
  padding: 12rpx 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.imp-input {
  height: 76rpx;
}

.bottom-note {
  text-align: center;
  font-size: 22rpx;
  color: #9ca3af;
  margin: 24rpx;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.footer-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.footer-btn.primary {
  background: #22c55e;
  color: #fff;
}
