.mutual-help-page {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  background: #ffffff;
}

/* Hero */
.hero {
  position: relative;
  z-index: 1;
  flex: 0 0 auto;
  width: 100%;
  padding: 28rpx 28rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
  background: linear-gradient(180deg, #00c853 0%, #00e676 45%, #1de9b6 100%);
  color: #ffffff;
  box-sizing: border-box;
}

.hero-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64rpx;
  margin-bottom: 40rpx;
}

.my-avatar-wrap {
  display: flex;
  align-items: center;
  height: 64rpx;
  gap: 14rpx;
}

.my-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.95);
}

.my-name {
  font-size: 32rpx;
  font-weight: 600;
}

.hero-text {
  margin-bottom: 40rpx;
  padding-left: 32rpx;
}

.hero-title {
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 60rpx;
  font-weight: 100;
  opacity: 0.9;
}

/* Helper list */
.helper-scroll {
  width: 100%;
  white-space: nowrap;
}

.helper-list {
  display: inline-flex;
  gap: 28rpx;
  padding: 8rpx 4rpx 16rpx;
}

.helper-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.helper-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  border: 4rpx solid transparent;
}

.helper-item.active .helper-avatar {
  border-color: #ffffff;
  background: rgba(255, 255, 255, 0.45);
}

.helper-item.add .helper-avatar {
  background: rgba(255, 255, 255, 0.25);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.add-icon {
  font-size: 48rpx;
  font-weight: 300;
  color: #ffffff;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.helper-name {
  font-size: 24rpx;
  opacity: 0.95;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Content */
.content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  flex: 1;
  width: 100%;
  background: #ffffff;
  overflow: hidden;
  box-sizing: border-box;
}

.content-scroll {
  width: 100%;
  flex: 1;
  padding: 72rpx 0 0;
  box-sizing: border-box;
}

.section-header {
  margin-bottom: 48rpx;
  padding: 0 60rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 300;
  color: #162116;
}

.section-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8b9a93;
}

/* Lucky cards */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.lucky-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: #f5f7fa;
  margin: 0 48rpx;
}


.lucky-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00d26a 0%, #00c2a8 100%);
  flex: 0 0 96rpx;
}

.lucky-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}

.lucky-title {
  font-size: 28rpx;
  font-weight: 400;
  color: #162116;
}

.lucky-desc {
  font-size: 26rpx;
  color: #6b7a73;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lucky-meta {
  font-size: 22rpx;
  color: #9baaa3;
}

.content-bottom-space {
  height: calc(260rpx + env(safe-area-inset-bottom));
}

/* 底部渐变遮罩，防止滚动内容遮挡 tab-bar */
.bottom-fade {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 15;
  height: calc(340rpx + env(safe-area-inset-bottom));
  pointer-events: none;
  background: linear-gradient(0deg, #ffffff 0%, #ffffff 40%, rgba(255, 255, 255, 0.95) 60%, rgba(255, 255, 255, 0.7) 80%, rgba(255, 255, 255, 0) 100%);
}
