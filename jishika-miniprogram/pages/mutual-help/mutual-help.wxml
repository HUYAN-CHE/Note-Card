<view class="mutual-help-page">
  <!-- 顶部绿色 Hero -->
  <view class="hero" style="padding-top: {{heroPaddingTop}}rpx;">
    <view class="hero-header">
      <view class="my-avatar-wrap" bindtap="onMyProfileTap" data-action="open_my_home">
        <view class="my-avatar"></view>
        <text class="my-name">Julian</text>
      </view>
    </view>

    <view class="hero-text">
      <view class="hero-title">一起协作过的人</view>
      <view class="hero-subtitle">同频的人，终会相遇</view>
    </view>

    <!-- 协作人头像列表 -->
    <view class="helper-row">
      <view
        class="helper-item add"
        bindtap="onHelperTap"
        data-id="add"
        data-action="add_helper"
      >
        <view class="helper-avatar">
          <text class="add-icon">+</text>
        </view>
        <text class="helper-name">添加</text>
      </view>

      <scroll-view class="helper-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="helper-list">
          <view
            wx:for="{{helpers}}"
            wx:key="id"
            wx:if="{{item.type !== 'add'}}"
            class="helper-item {{item.id === selectedHelperId ? 'active' : ''}}"
            bindtap="onHelperTap"
            data-id="{{item.id}}"
            data-action="select_helper"
          >
            <view class="helper-avatar" style="background: {{item.color}};">
              <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill" />
              <text wx:else class="avatar-initial">{{item.initial}}</text>
            </view>
            <text class="helper-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 内容区 -->
  <view class="content">
    <view class="section-header">
      <text class="section-title">TA和朋友们需要什么</text>
    </view>

    <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}" style="height: {{contentScrollHeight}}px">
      <view class="card-list">
        <view
          wx:for="{{cards}}"
          wx:key="id"
          class="lucky-card"
          bindtap="onCardTap"
          data-id="{{item.id}}"
          data-action="open_card_detail"
        >
          <view class="lucky-circle"></view>
          <view class="lucky-info">
            <text class="lucky-title">{{item.title}}</text>
            <text class="lucky-desc">{{item.desc}}</text>
            <text class="lucky-meta">{{item.relation}} · {{item.creatorName}} · {{item.status}}</text>
          </view>
        </view>
      </view>

      <view class="content-bottom-space"></view>
    </scroll-view>
  </view>

  <view class="bottom-fade"></view>
  <tab-bar activeTab="mutual-help" />
</view>
