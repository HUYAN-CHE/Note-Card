<view class="page">
  <view class="topbar">
    <view>
      <view class="brand-title">服务进度</view>
      <view class="brand-subtitle">{{role === 'customer' ? '当前只显示你需要知道的内容' : '节点、提醒和客户可见进度'}}</view>
    </view>
    <text class="tag">{{card.stage || '进行中'}}</text>
  </view>

  <view wx:if="{{card.id}}" class="card panel">
    <view class="item-title">{{card.projectName}}</view>
    <view class="item-meta">{{card.customerName || '客户'}}｜{{card.summary}}</view>

    <view class="timeline">
      <view wx:for="{{card.progressNodes}}" wx:key="id" class="node {{item.status}}">
        <view class="node-mark" aria-hidden="true">{{item.status === 'done' ? '✓' : item.status === 'current' ? '•' : ''}}</view>
          <view class="node-main">
            <view class="node-title">{{item.title}}</view>
          <view class="node-status">{{item.statusText}}</view>
          </view>
        <button wx:if="{{role !== 'customer' && item.status !== 'done'}}" class="node-action" bindtap="completeNode" data-id="{{item.id}}" data-action="complete_progress_node" aria-label="完成节点 {{item.title}}">完成</button>
      </view>
    </view>
  </view>

  <view wx:else class="empty">这张记事卡不存在或已被删除。</view>

  <view wx:if="{{card.id}}" class="action-dock">
    <button wx:if="{{role !== 'customer'}}" class="primary-action" bindtap="requestReminder" data-action="request_reminder" aria-label="设置节点提醒">
      <view>
        <text class="title">设提醒</text>
        <text class="desc">{{card.reminderText || '记录下一步提醒'}}</text>
      </view>
      <text class="arrow">⏱</text>
    </button>
    <button wx:else class="primary-action" bindtap="completeService" data-action="complete_service" aria-label="标记服务完成">
      <view>
        <text class="title">服务完成</text>
        <text class="desc">确认当前服务结束</text>
      </view>
      <text class="arrow">✓</text>
    </button>
    <view class="action-tools">
      <button wx:if="{{role !== 'customer'}}" class="tool-button" open-type="share" data-action="share_progress" aria-label="分享服务进度给客户">
        <text class="tool-icon" aria-hidden="true">↗</text>
        <text class="tool-label">分享</text>
      </button>
      <button wx:if="{{role !== 'customer'}}" class="tool-button" bindtap="completeService" data-action="complete_service" aria-label="标记服务完成">
        <text class="tool-icon" aria-hidden="true">✓</text>
        <text class="tool-label">完成</text>
      </button>
    </view>
  </view>
</view>
