.capsule-wrap {
  position: relative;
  width: 460rpx;
  height: 120rpx;
  margin: 34rpx 0 60rpx;
}

.capsule-canvas,
.capsule-inner {
  position: absolute;
  margin: 0;
  padding: 0;
}

.capsule-canvas {
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.capsule-inner {
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.92);
  font-size: 32rpx;
  font-weight: 750;
  letter-spacing: 0;
  line-height: 1;
}

.capsule-plus {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 36rpx;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.capsule-label {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 32rpx;
  font-size: 32rpx;
  font-weight: 750;
  line-height: 1;
}
