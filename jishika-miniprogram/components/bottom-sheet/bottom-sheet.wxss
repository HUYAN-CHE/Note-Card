.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0);
  display: flex;
  align-items: flex-end;
  pointer-events: none;
  transition: background 0.25s ease;
}

.sheet-mask.show {
  pointer-events: auto;
  background: rgba(0, 0, 0, 0.45);
}

.sheet {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 32rpx;
  transform: translateY(100%);
  transition: transform 0.25s ease-out;
}

.sheet-mask.show .sheet {
  transform: translateY(0);
}

.sheet-grab {
  width: 64rpx;
  height: 6rpx;
  background: #e0e0e0;
  border-radius: 3rpx;
  margin: 0 auto 24rpx;
}

.sheet-header {
  margin-bottom: 24rpx;
}

.sheet-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #162116;
  text-align: center;
}

.sheet-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #68705f;
  text-align: center;
}
