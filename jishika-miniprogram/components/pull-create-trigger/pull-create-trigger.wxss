.pull-create-trigger {
  position: relative;
  min-height: 100vh;
  background: transparent;
}

.hero-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  background:
    radial-gradient(circle at 50% 46%, rgba(255, 255, 255, 0.28) 0, rgba(255, 255, 255, 0) 220rpx),
    linear-gradient(180deg, #b8f0b0 0%, #5fc26b 100%);
}

.pull-hero {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 520rpx;
  padding: 0 44rpx 0;
  background: transparent;
  color: rgba(17, 31, 18, 0.92);
}

.hero-nav {
  align-self: flex-start;
  display: flex;
  align-items: center;
  height: 64rpx;
  margin-bottom: 24rpx;
}

.hero-nav-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #142115;
  line-height: 40rpx;
}

.week-strip {
  position: relative;
  width: calc(100% + 88rpx);
  height: 180rpx;
  margin: 40rpx -44rpx -40rpx;
  overflow: hidden;
}

.selection-frame {
  position: absolute;
  z-index: 1;
  left: 50%;
  top: 50%;
  width: 108rpx;
  height: 118rpx;
  border-radius: 54rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 44rpx rgba(58, 112, 54, 0.14);
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.week-track {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: row;
  width: 700vw;
  height: 100%;
  will-change: transform;
  transform-origin: 0 0;
}

.day-slot {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 20vw;
  height: 100%;
}

.day-item {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  width: 100%;
  height: 118rpx;
  border-radius: 60rpx;
  background: transparent;
}

.day-label {
  font-size: 24rpx;
  font-weight: 300;
  color: rgba(20, 35, 19, 0.5);
  line-height: 1;
}

.day-date {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 300;
  color: rgba(20, 35, 19, 0.5);
  line-height: 1;
}

.day-slot.today:not(.active) .day-label,
.day-slot.today:not(.active) .day-date {
  color: #ffffff;
  font-weight: 500;
}

.day-slot.active .day-label {
  color: rgba(20, 35, 19, 0.72);
  font-weight: 650;
}

.day-slot.active .day-date {
  color: #111816;
  font-weight: 800;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: rgba(20, 35, 19, 0.34);
}

.hero-title {
  margin-top: 70rpx;
  color: rgba(255, 255, 255, 0.94);
  font-size: 38rpx;
  font-weight: 500;
  line-height: 1.2;
  text-align: center;
  text-shadow: 0 10rpx 26rpx rgba(64, 130, 56, 0.22);
}

.capsule-wrap {
  position: relative;
  width: 460rpx;
  height: 120rpx;
  margin: 34rpx 0 60rpx;
}

.capsule-canvas,
.capsule-inner {
  position: absolute;
  margin: 0;
  padding: 0;
}

.capsule-canvas {
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 460rpx;
  height: 120rpx;
  display: block;
}

.capsule-inner {
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.92);
  font-size: 32rpx;
  font-weight: 750;
  letter-spacing: 0;
  line-height: 1;
}

.capsule-plus {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 36rpx;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.capsule-label {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 32rpx;
  font-size: 32rpx;
  font-weight: 750;
  line-height: 1;
}

.pull-sheet {
  position: sticky;
  z-index: 1;
  top: 0;
  display: flex;
  flex-direction: column;
  padding: 42rpx 40rpx calc(110rpx + env(safe-area-inset-bottom));
  border-radius: 44rpx 44rpx 0 0;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -24rpx 72rpx rgba(71, 135, 65, 0.12);
  will-change: transform;
  box-sizing: border-box;
}

.pull-sheet.returning {
  transition: transform 360ms cubic-bezier(0.2, 0.86, 0.22, 1);
}

.sheet-grabber {
  width: 58rpx;
  height: 8rpx;
  margin: 0 auto 34rpx;
  border-radius: 999rpx;
  background: rgba(19, 30, 21, 0.16);
}
