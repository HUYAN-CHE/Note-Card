.pull-create-trigger {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 46%, rgba(255, 255, 255, 0.28) 0, rgba(255, 255, 255, 0) 220rpx),
    linear-gradient(180deg, #bdf5b8 0%, #a9eca3 54%, #eff8e5 100%);
}

.pull-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 520rpx;
  padding: 0 44rpx 0;
  color: rgba(17, 31, 18, 0.92);
}

.hero-nav {
  align-self: flex-start;
  display: flex;
  align-items: center;
  height: 64rpx;
  margin-bottom: 24rpx;
}

.hero-nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #142115;
  line-height: 44rpx;
}

.week-row {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  align-items: center;
  gap: 8rpx;
  margin-top: 40rpx;
}

.day-item {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  min-height: 118rpx;
  border-radius: 54rpx;
}

.day-item.active {
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(58, 112, 54, 0.16);
}

.day-label {
  color: rgba(20, 35, 19, 0.72);
  font-size: 24rpx;
  font-weight: 650;
}

.day-date {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: rgba(20, 35, 19, 0.34);
}

.hero-title {
  margin-top: 70rpx;
  color: rgba(255, 255, 255, 0.94);
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
  text-shadow: 0 10rpx 26rpx rgba(64, 130, 56, 0.22);
}

.capsule-wrap {
  position: relative;
  width: 460rpx;
  height: 120rpx;
  margin: 34rpx 0 60rpx;
}

.capsule-canvas,
.capsule-inner {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 460rpx;
  height: 120rpx;
  margin: 0;
  padding: 0;
}

.capsule-canvas {
  display: block;
}

.capsule-inner {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.01);
  color: rgba(255, 255, 255, 0.92);
  font-size: 32rpx;
  font-weight: 750;
  letter-spacing: 0;
  line-height: 1;
}

.capsule-plus {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 36rpx;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.capsule-label {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 32rpx;
  font-size: 32rpx;
  font-weight: 750;
  line-height: 1;
}

.pull-sheet {
  position: relative;
  min-height: 780rpx;
  margin-top: 10rpx;
  padding: 42rpx 40rpx calc(110rpx + env(safe-area-inset-bottom));
  border-radius: 44rpx 44rpx 0 0;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -24rpx 72rpx rgba(71, 135, 65, 0.12);
  will-change: transform;
}

.pull-sheet.returning {
  transition: transform 360ms cubic-bezier(0.2, 0.86, 0.22, 1);
}

.sheet-grabber {
  width: 58rpx;
  height: 8rpx;
  margin: 0 auto 34rpx;
  border-radius: 999rpx;
  background: rgba(19, 30, 21, 0.16);
}
