/* 底部 Tab */
.tab-bar {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-sizing: border-box;
  height: 100rpx;
  padding: 14rpx;
  border-radius: 999rpx;
  background: #fff;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-width: 220rpx;
  height: 100%;
  padding: 0 42rpx;
  border-radius: 999rpx;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: #DCFCE7;
}

.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 400;
  line-height: 1;
  color: #9CA3AF;
}



.tab-item.active .tab-icon {
  color: #166534;
}

.menu-icon {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  width: 26rpx;
  height: 24rpx;
}

.menu-line {
  width: 100%;
  height: 3rpx;
  background: currentColor;
}

.tab-item.active .menu-icon {
  width: 30rpx;
  height: 26rpx;
}

.tab-item.active .menu-line {
  height: 4rpx;
}

.mutual-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.mutual-ring {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 3rpx solid currentColor;
  box-sizing: border-box;
}

.tab-item.active .mutual-ring {
  width: 32rpx;
  height: 32rpx;
  border-width: 4rpx;
}

.tab-label {
  font-size: 28rpx;
  font-weight: 400;
  color: #9CA3AF;
}

.tab-item.active .tab-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #166534;
}
