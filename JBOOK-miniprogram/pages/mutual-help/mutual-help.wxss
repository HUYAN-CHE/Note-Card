.mutual-help-page {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  background: #ffffff;
}

/* Hero */
.hero {
  position: relative;
  z-index: 1;
  flex: 0 0 auto;
  width: 100%;
  padding: 28rpx 28rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
  background: linear-gradient(180deg, #00c853 0%, #00e676 45%, #1de9b6 100%);
  color: #ffffff;
  box-sizing: border-box;
}

.hero-header {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 64rpx;
  margin-bottom: 70rpx;
}

.my-avatar-wrap {
  display: flex;
  align-items: center;
  height: 64rpx;
  gap: 8rpx;
  width: auto;
}

.my-avatar-wrap-link {
  padding: 0;
  margin: 0;
  background: transparent;
}

.my-avatar-wrap-link::after {
  border: none;
}

.my-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  overflow: hidden;
}

.my-avatar-initial {
  font-size: 28rpx;
  font-weight: 600;
  color: #00c853;
}

.my-avatar-img {
  width: 100%;
  height: 100%;
}

.my-avatar-btn {
  width: 64rpx !important;
  height: 64rpx !important;
  min-width: 0 !important;
  min-height: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  border-radius: 50% !important;
  background: rgba(255, 255, 255, 0.9) !important;
  line-height: 1;
  overflow: hidden;
  box-sizing: border-box;
}

.my-avatar-btn::after {
  display: none;
}

.my-avatar-unauthorized {
  background: #e0e4e8 !important;
  border: none !important;
}

.my-name {
  display: inline-flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
}

.my-name-input {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  width: auto;
  min-width: 0;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
}

.hero-text {
  margin-bottom: 80rpx;
  padding-left: 32rpx;
}

.hero-title {
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 60rpx;
  font-weight: 100;
  opacity: 0.9;
}

/* Helper list */
.helper-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-top: 28rpx;
  padding: 8rpx 0 16rpx;
  box-sizing: border-box;
}

.helper-scroll {
  flex: 1;
  width: auto;
  min-width: 0;
  white-space: nowrap;
}

.helper-list {
  display: inline-flex;
  gap: 28rpx;
  padding-right: 28rpx;
}

.helper-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.helper-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  border: 4rpx solid transparent;
}

.helper-item.active .helper-avatar {
  border-color: #ffffff;
  background: rgba(255, 255, 255, 0.45);
}

.helper-item.add .helper-avatar {
  background: rgba(255, 255, 255, 0.25);
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

.add-icon {
  display: block;
  width: 100%;
  height: 112rpx;
  font-size: 44rpx;
  font-weight: 300;
  line-height: 112rpx;
  text-align: center;
  color: #ffffff;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-initial {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.helper-name {
  width: 100rpx;
  font-size: 24rpx;
  text-align: center;
  opacity: 0.95;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Content */
.content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  flex: 1;
  width: 100%;
  background: #ffffff;
  overflow: hidden;
  box-sizing: border-box;
}

.section-header {
  padding: 72rpx 60rpx 48rpx;
  background: #ffffff;
}

.content-scroll {
  width: 100%;
  flex: 1;
  box-sizing: border-box;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 300;
  color: #162116;
}

.section-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8b9a93;
}

/* Lucky cards */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.lucky-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: #f5f7fa;
  margin: 0 48rpx;
}


.lucky-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00d26a 0%, #00c2a8 100%);
  flex: 0 0 96rpx;
}

.lucky-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}

.lucky-title {
  font-size: 28rpx;
  font-weight: 400;
  color: #162116;
}

.lucky-desc {
  font-size: 26rpx;
  color: #6b7a73;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lucky-meta {
  font-size: 22rpx;
  color: #9baaa3;
}

.card-loading,
.card-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.card-loading-text,
.card-empty-text {
  font-size: 26rpx;
  color: #9baaa3;
  text-align: center;
}

.content-bottom-space {
  height: calc(260rpx + env(safe-area-inset-bottom));
}

/* 底部渐变遮罩，防止滚动内容遮挡 tab-bar */
.bottom-fade {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 15;
  height: calc(240rpx + env(safe-area-inset-bottom));
  pointer-events: none;
  background: linear-gradient(0deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.95) 40%, rgba(255, 255, 255, 0.98) 60%, rgba(255, 255, 255, 0.75) 80%, rgba(255, 255, 255, 0) 100%);
}
