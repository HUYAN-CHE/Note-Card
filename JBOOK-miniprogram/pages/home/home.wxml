<view class="page home-page">
  <pull-create-trigger
    class="home-pull-trigger"
    bind:trigger="onPullCreate"
    bind:selectDay="selectDay"
    title="生活由无数的小事组成"
    label="下拉新建事项"
    threshold="{{150}}"
    max-drag="{{188}}"
    week-days="{{weekDays}}"
    selected-index="{{selectedIndex}}"
    status-bar-height="{{statusBarHeight}}"
    body-pull-enabled="{{!cards.length || !bodyCanScroll}}"
  >
    <view slot="sheet-head">
      <view class="sheet-grabber"></view>

      <view class="sheet-head">
        <view class="sheet-title-wrap">
          <text class="sheet-title">最近记事卡</text>
          <text class="sheet-subtitle">打开临近消息提醒</text>
        </view>
        <view
          class="reminder-switch-wrap"
          catchtouchmove="onPreventTouchMove"
        >
          <switch
            class="reminder-switch"
            checked="{{reminderEnabled}}"
            color="#22C55E"
            bindchange="toggleReminder"
            aria-label="打开临近消息提醒"
          />
        </view>
      </view>
    </view>

    <pull-refresh-view
      wx:if="{{cards.length}}"
      class="card-list-scroll"
      refresher-enable="{{false}}"
      scroll-y="{{true}}"
      refreshing="{{refreshing}}"
      show-loading="{{false}}"
      bindscroll="onBodyScroll"
      bind:refreshclose="onPullCreateClose"
    >
      <view class="card-list">
        <view
          wx:for="{{cards}}"
          wx:key="id"
          class="card-item"
          bindtap="openCard"
          data-id="{{item.id}}"
          data-action="open_card"
          aria-label="打开记事卡 {{item.displayTitle}}"
        >
          <view class="card-icon">{{item.emoji}}</view>

          <view class="card-info">
            <text class="card-title">{{item.displayTitle}}</text>
            <text class="card-meta">截止日期 {{item.deadlineText}}</text>
          </view>

          <view class="card-status {{item.statusClass}}" aria-hidden="true">
            <text class="status-text">{{item.statusText}}</text>
          </view>
        </view>
      </view>
    </pull-refresh-view>

    <view wx:else class="empty-state">
      <image class="empty-image" src="/assets/images/empty-state-ref.png" mode="aspectFit" aria-hidden="true" />
      <text class="empty-title">还没有记事卡</text>
      <text class="empty-sub">下拉或点击上方按钮，从聊天记录生成一张记事卡</text>
    </view>
  </pull-create-trigger>

  <tab-bar activeTab="home" />

  <!-- 首次登录授权弹窗 -->
  <view class="auth-mask" wx:if="{{showAuthModal}}" catchtap="closeAuthModal">
    <view class="auth-modal" catchtap="onPreventBubble">
      <view class="auth-title">授权登录</view>
      <view class="auth-desc">分别点击头像和昵称完成授权</view>
      <view class="auth-actions">
        <button
          class="auth-avatar-btn {{authProfile.avatar ? 'done' : ''}}"
          open-type="chooseAvatar"
          bind:chooseavatar="onAuthAvatar"
        >
          <text wx:if="{{!authProfile.avatar}}">点击授权头像</text>
          <image wx:else class="auth-avatar-img" src="{{authProfile.avatar}}" mode="aspectFill" />
        </button>
        <input
          class="auth-nickname-input {{authProfile.nickname ? 'done' : ''}}"
          type="nickname"
          placeholder="点击输入昵称"
          value="{{authProfile.nickname}}"
          bindinput="onAuthNicknameInput"
          maxlength="20"
        />
      </view>
      <view class="auth-close" bindtap="closeAuthModal">稍后再说</view>
    </view>
  </view>
</view>
