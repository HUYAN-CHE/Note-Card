/* pages/home/home.wxss */

.home-page {
  position: relative;
  min-height: 100vh;
  padding: 0;
  overflow: hidden;
  background: linear-gradient(180deg, #00c853 0%, #00e676 45%, #1de9b6 100%);
}

/* Sheet 头部 */
.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.sheet-title-wrap {
  display: flex;
  flex-direction: column;
}

.sheet-title {
  color: #111816;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 42rpx;
}

.sheet-subtitle {
  margin-top: 4rpx;
  color: #9aa19c;
  font-size: 26rpx;
  line-height: 36rpx;
}

.reminder-switch-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.reminder-switch {
  transform: scale(0.84);
  transform-origin: right top;
}

/* 卡片列表 */
.card-list-scroll {
  flex: 1;
  min-height: 0;
  height: 100%;
  margin-top: 34rpx;
}

.create-refresher {
  height: 80px;
}

.sheet-grabber {
  width: 58rpx;
  height: 8rpx;
  margin: 0 auto 34rpx;
  border-radius: 999rpx;
  background: rgba(19, 30, 21, 0.16);
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 左滑删除：底层删除按钮 + 内容层位移；wrap 背景与卡片同色，遮盖内容层圆角透出的红边 */
.swipe-wrap {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  background: #f4f5f7;
}

.swipe-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: #e53935;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.swipe-content {
  position: relative;
  z-index: 1;
  transition: transform 0.2s ease;
}

.card-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #f4f5f7;
  border-radius: 24rpx;
}

.card-icon {
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111816;
  line-height: 44rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-meta {
  font-size: 24rpx;
  color: #a0a5a1;
  line-height: 34rpx;
  margin-top: 8rpx;
}

.card-status {
  flex-shrink: 0;
  padding: 10rpx 22rpx;
  border-radius: 28rpx;
  margin-left: 16rpx;
  background: #fff;
  border: 1rpx solid rgba(17, 24, 22, 0.08);
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #68706a;
}

.status-done {
  background: #dcfce7;
  border-color: transparent;
}

.status-done .status-text {
  color: #16a34a;
}

/* 授权弹窗 */
.auth-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.5);
}

.auth-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  padding: 48rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.auth-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #162116;
  text-align: center;
}

.auth-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #6b7a73;
  text-align: center;
}

.auth-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-top: 40rpx;
}

.auth-avatar-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  width: 140rpx !important;
  height: 140rpx !important;
  min-width: 0 !important;
  min-height: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  border-radius: 50% !important;
  background: #f5f7fa !important;
  font-size: 24rpx;
  color: #6b7a73;
  box-sizing: border-box;
  overflow: hidden;
}

.auth-avatar-btn::after {
  display: none;
}

.auth-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.auth-nickname-input {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 80rpx;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 999rpx;
  background: #f5f7fa;
  font-size: 28rpx;
  color: #162116;
  line-height: 1;
  text-align: center;
}

.auth-nickname-input.done {
  background: #e8f5e9;
  color: #22c55e;
}

.auth-close {
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #9baaa3;
  text-align: center;
}
