<view class="page card-edit-page">
  <custom-nav title="{{card.id ? '编辑记事卡' : '新建记事卡'}}" showBack="{{true}}" statusBarHeight="{{statusBarHeight}}" navHeight="{{navHeight}}">
    <view slot="right" class="nav-save" bindtap="saveAndBack">保存</view>
  </custom-nav>

  <!-- 顶部固定快速创建浮层 -->
  <view class="float-create-card" style="top: {{totalHeight}}px;">
    <view class="create-card compact">
      <view class="create-card-header">
        <view class="create-card-title-wrap">
          <view class="create-card-title">快速识别创建</view>
          <view class="create-card-subtitle">粘贴聊天内容或语音输入，自动识别生成记事卡</view>
        </view>
      </view>
      <textarea
        class="create-card-input"
        value="{{parseInputText}}"
        placeholder="粘贴或输入内容"
        bindinput="onParseInput"
        maxlength="4000"
        adjust-position="{{true}}"
      />
      <view class="create-card-actions">
        <view class="create-btn primary {{isParsing ? 'disabled' : ''}}" bindtap="parseFromInput">
          <image class="create-btn-icon white" src="/assets/images/icon-paste.svg" mode="aspectFit"/>
          <text>{{isParsing ? '识别中...' : '粘贴识别'}}</text>
        </view>
        <view class="create-btn {{isRecording ? 'recording' : ''}} {{isParsing ? 'disabled' : ''}}" bindtap="startVoiceInput">
          <image class="create-btn-icon" src="/assets/images/icon-mic.svg" mode="aspectFit"/>
          <text>{{isRecording ? '录音中...' : '语音输入'}}</text>
        </view>
      </view>
      <view class="vip-banner" bindtap="onChatCreateTap">
        <image class="vip-banner-icon" src="/assets/images/icon-crown.svg" mode="aspectFit"/>
        <view class="vip-banner-text">
          <text class="vip-banner-title">AI 聊天创建</text>
          <text class="vip-banner-desc">会员专享 · 聊天记录一键生成</text>
        </view>
        <view class="vip-banner-btn">立即开通</view>
      </view>
    </view>
  </view>

  <scroll-view class="form-scroll" scroll-y style="height: {{contentHeight}}px; margin-top: {{totalHeight + floatCardHeightPx}}px;">
    <view class="form">
      <!-- 信息卡片 -->
      <view class="info-card">
        <!-- 标题 -->
        <view class="field">
          <view class="field-label">标题 <text class="required">*</text></view>
          <input
            class="field-input"
            value="{{card.title}}"
            placeholder="如 品牌官网视觉改版"
            bindinput="onTitleInput"
            adjust-position="{{true}}"
          />
        </view>

        <!-- 需求描述 -->
        <view class="field">
          <view class="field-label">需求描述</view>
          <textarea
            class="field-textarea"
            value="{{card.desc}}"
            placeholder="描述一下需要帮忙的事"
            bindinput="onDescInput"
            adjust-position="{{true}}"
          />
        </view>

        <!-- 截止日期 -->
        <view class="field">
          <view class="field-label">截止日期</view>
          <picker mode="date" value="{{card.deadline}}" bindchange="onDeadlineChange">
            <view class="field-input deadline-input {{card.deadline ? '' : 'is-placeholder'}}">
              {{card.deadline || '请选择日期'}}
            </view>
          </picker>
        </view>

        <!-- 重点 / 待确认 -->
        <view class="field">
          <view class="field-label">
            重点 / 待确认
            <text class="field-hint">用 · 分隔</text>
          </view>
          <input
            class="field-input"
            value="{{keyPointsText}}"
            placeholder="预算 · 风格 · 交期"
            bindinput="onKeyPointsInput"
            adjust-position="{{true}}"
          />
        </view>

        <!-- 图片附件 -->
        <view class="field">
          <view class="field-label">图片附件（选填）</view>
          <view class="attachment-list" wx:if="{{attachmentImages.length}}">
            <view class="attachment-item" wx:for="{{attachmentImages}}" wx:key="index">
              <image src="{{item.tempPath}}" class="attachment-thumb" mode="aspectFill" bindtap="previewAttachment" data-index="{{index}}" />
              <view class="attachment-remove" bindtap="removeAttachment" data-index="{{index}}">×</view>
            </view>
          </view>
          <view class="attachment-add" bindtap="chooseAttachmentImages">+ 添加图片</view>
        </view>

        <!-- 可见性开关 -->
        <view class="toggle-row" bindtap="toggleVisibility">
          <view class="toggle-info">
            <view class="toggle-title">让朋友的朋友也能看到</view>
            <view class="toggle-desc">关闭后仅共同行动人可见，更私密</view>
          </view>
          <view class="switch {{card.isNetworkVisible ? 'on' : ''}}">
            <view class="switch-knob"></view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部操作 -->
  <view class="footer" style="padding-bottom: calc(24rpx + {{safeAreaBottom}}px);">
    <button class="footer-btn primary" bindtap="generateCard">{{card.id ? '保存，去邀请共同行动人' : '生成记事卡'}}</button>
  </view>
</view>
