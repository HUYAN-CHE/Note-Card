.card-edit-page {
  padding: 0;
}

.form-scroll {
  box-sizing: border-box;
}

.nav-save {
  font-size: 30rpx;
  color: #4caf50;
  font-weight: 700;
}

.form {
  padding: 24rpx 28rpx 48rpx;
}

.field {
  margin-bottom: 40rpx;
}

.field-label {
  position: relative;
  padding-left: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
  margin-bottom: 20rpx;
}

.field-label::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #4caf50;
}

.required {
  color: #e53935;
}

.field-hint {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

.field-input {
  width: 100%;
  height: 88rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  background: transparent;
  border-bottom: 1rpx solid #ececec;
  border-radius: 0;
  font-size: 30rpx;
  color: #333;
}

.field-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 12rpx 8rpx;
  box-sizing: border-box;
  background: transparent;
  border-bottom: 1rpx solid #ececec;
  border-radius: 0;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

/* 截止日期 */
.deadline-input {
  display: flex;
  align-items: center;
  color: #333;
}

.deadline-input.is-placeholder {
  color: #999;
}

/* 图片附件 */
.attachment-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.attachment-item {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f8f9fa;
}

.attachment-thumb {
  width: 144rpx;
  height: 144rpx;
}

.attachment-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.attachment-add {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 32rpx;
  background: #f8f9fa;
  border: 2rpx dashed #c8c8c8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

/* 可见性开关 */
.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  margin-top: 8rpx;
}

.toggle-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
}

.toggle-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999;
}

.switch {
  position: relative;
  width: 88rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #e0e0e0;
  transition: background 0.2s ease;
}

.switch.on {
  background: #4caf50;
}

.switch-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.2s ease;
}

.switch.on .switch-knob {
  transform: translateX(40rpx);
}

/* 底部 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.03);
  z-index: 50;
}

.footer-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  text-align: center;
}

.footer-btn::after {
  display: none;
}

.footer-btn.primary {
  color: #fff;
  background: #4caf50;
}

/* 顶部固定快速创建浮层 */
.float-create-card {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 99;
  padding: 0 28rpx 20rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(12rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

/* 快速创建卡片 */
.create-card {
  padding: 24rpx;
  background: linear-gradient(150deg, #b8f0cf 0%, #a8ebc5 50%, #b8f0df 100%);
  border-radius: 24rpx;
}

.create-card.compact {
  padding: 24rpx;
}

.create-card-header {
  margin-bottom: 20rpx;
}

.create-card-title-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
}

.create-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #162116;
}

.create-card-subtitle {
  font-size: 24rpx;
  color: #7a8a7a;
  line-height: 1.5;
}

/* VIP 入口横幅：单行紧凑排布，会员金色 + 主题绿点缀 */
.vip-banner {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 18rpx 20rpx 18rpx 24rpx;
  background: linear-gradient(135deg, #fdf3d8 0%, #fbe7b4 100%);
  border-radius: 20rpx;
}

.vip-banner-icon {
  width: 34rpx;
  height: 34rpx;
  flex: none;
  filter: invert(55%) sepia(65%) saturate(550%) hue-rotate(2deg) brightness(92%);
}

.vip-banner-text {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-left: 14rpx;
  white-space: nowrap;
  overflow: hidden;
}

.vip-banner-title {
  flex: none;
  font-size: 26rpx;
  font-weight: 700;
  color: #8a6414;
}

.vip-banner-desc {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #b08d3e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vip-banner-btn {
  flex: none;
  margin-left: 16rpx;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #a87e1e 0%, #8a6414 100%);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.create-card-input {
  width: 100%;
  height: 140rpx;
  min-height: 140rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.95);
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.create-card-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.create-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 72rpx;
  padding: 0;
  background: rgba(255, 255, 255, 0.95);
  border: none;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #162116;
}

.create-btn.primary {
  background: #101816;
  color: #f7f2e8;
}

.create-btn.recording {
  background: #e53935;
  color: #fff;
  animation: pulse 1.2s infinite;
}

.create-btn.disabled {
  opacity: 0.5;
}

.create-btn-icon {
  width: 32rpx;
  height: 32rpx;
  flex: none;
}

.create-btn-icon.white {
  filter: brightness(0) invert(1);
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* 信息卡片 */
.info-card {
  padding: 36rpx 32rpx;
  background: #fff;
  border-radius: 28rpx;
}

.info-card .field:last-child {
  margin-bottom: 0;
}

.info-card .toggle-row {
  padding: 28rpx 0 0;
  margin-top: 8rpx;
  border-top: 1rpx solid #f2f2f2;
}
