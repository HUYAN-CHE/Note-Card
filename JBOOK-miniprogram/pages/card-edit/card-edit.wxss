.card-edit-page {
  padding-bottom: 160rpx;
}

.nav-save {
  font-size: 30rpx;
  color: #4caf50;
  font-weight: 700;
}

.form {
  padding: 0 28rpx;
}

.field {
  margin-bottom: 32rpx;
}

.field-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #162116;
  margin-bottom: 14rpx;
}

.required {
  color: #e53935;
}

.field-hint {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

.field-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.field-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 协助者 */
.helper-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.helper-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

.helper-avatar image {
  width: 64rpx;
  height: 64rpx;
}

.helper-add {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

/* 可见性开关 */
.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  margin-top: 8rpx;
}

.toggle-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
}

.toggle-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999;
}

.switch {
  position: relative;
  width: 96rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e0e0e0;
  transition: background 0.2s ease;
}

.switch.on {
  background: #4caf50;
}

.switch-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.2s ease;
}

.switch.on .switch-knob {
  transform: translateX(40rpx);
}

/* 底部 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 50;
}

.footer-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  text-align: center;
}

.footer-btn::after {
  display: none;
}

.footer-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.footer-btn.primary {
  flex: 1.4;
  color: #fff;
  background: #4caf50;
}

/* 邀请 Sheet */
.friend-list {
  max-height: 560rpx;
  overflow-y: auto;
}

.friend-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
}

.friend-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.friend-avatar image {
  width: 72rpx;
  height: 72rpx;
}

.friend-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.friend-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
}

.friend-status {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999;
}

.friend-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.friend-check.on {
  background: #4caf50;
  border-color: #4caf50;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.sheet-btn::after {
  display: none;
}

.sheet-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.sheet-btn.primary {
  color: #fff;
  background: #4caf50;
}
