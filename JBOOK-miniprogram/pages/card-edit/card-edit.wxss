.card-edit-page {
  padding: 0;
}

.form-scroll {
  box-sizing: border-box;
}

.nav-save {
  font-size: 30rpx;
  color: #4caf50;
  font-weight: 700;
}

.form {
  padding: 16rpx 28rpx 32rpx;
}

.field {
  margin-bottom: 36rpx;
}

.field-label {
  position: relative;
  padding-left: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
  margin-bottom: 18rpx;
}

.field-label::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #4caf50;
}

.required {
  color: #e53935;
}

.field-hint {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

.field-input {
  width: 100%;
  height: 80rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  background: transparent;
  border-bottom: 1rpx solid #e8e8e8;
  border-radius: 0;
  font-size: 30rpx;
  color: #333;
}

.field-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 12rpx 8rpx;
  box-sizing: border-box;
  background: transparent;
  border-bottom: 1rpx solid #e8e8e8;
  border-radius: 0;
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

/* 共同行动人 */
.helper-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.helper-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

.helper-avatar image {
  width: 64rpx;
  height: 64rpx;
}

.helper-add {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

/* 图片附件 */
.attachment-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.attachment-item {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f8f9fa;
}

.attachment-thumb {
  width: 144rpx;
  height: 144rpx;
}

.attachment-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.attachment-add {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 32rpx;
  background: #f8f9fa;
  border: 2rpx dashed #c8c8c8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

/* 可见性开关 */
.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  margin-top: 8rpx;
}

.toggle-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
}

.toggle-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999;
}

.switch {
  position: relative;
  width: 88rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #e0e0e0;
  transition: background 0.2s ease;
}

.switch.on {
  background: #4caf50;
}

.switch-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.2s ease;
}

.switch.on .switch-knob {
  transform: translateX(40rpx);
}

/* 底部 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 50;
}

.footer-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  text-align: center;
}

.footer-btn::after {
  display: none;
}

.footer-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.footer-btn.primary {
  flex: 1.4;
  color: #fff;
  background: #4caf50;
}

/* 邀请 Sheet */
.friend-list {
  max-height: 560rpx;
  overflow-y: auto;
}

.friend-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
}

.friend-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.friend-avatar image {
  width: 72rpx;
  height: 72rpx;
}

.friend-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.friend-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
}

.friend-status {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999;
}

.friend-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.friend-check.on {
  background: #4caf50;
  border-color: #4caf50;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.sheet-btn::after {
  display: none;
}

.sheet-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.sheet-btn.primary {
  color: #fff;
  background: #4caf50;
}

/* 顶部固定快速创建浮层 */
.float-create-card {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 99;
  padding: 0 28rpx 16rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* 快速创建卡片 */
.create-card {
  padding: 24rpx;
  background: linear-gradient(150deg, #b8f0cf 0%, #a8ebc5 50%, #b8f0df 100%);
  border-radius: 24rpx;
}

.create-card.compact {
  padding: 20rpx 22rpx;
}

.create-card-header {
  margin-bottom: 16rpx;
}

.create-card-title-wrap {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12rpx;
}

.create-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #162116;
}

.create-card-subtitle {
  font-size: 24rpx;
  color: #7a8a7a;
  line-height: 1.4;
}

/* VIP 入口横幅 */
.vip-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  background: linear-gradient(135deg, #2d2f3a 0%, #1a1c23 100%);
  border-radius: 20rpx;
}

.vip-banner-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.vip-banner-icon {
  width: 40rpx;
  height: 40rpx;
  filter: brightness(0) invert(1);
}

.vip-banner-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.vip-banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffd700;
}

.vip-banner-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.vip-banner-btn {
  padding: 10rpx 22rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.create-card-input {
  width: 100%;
  height: 150rpx;
  min-height: 150rpx;
  padding: 16rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.create-card-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.create-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 16rpx 0;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #162116;
}

.create-btn.primary {
  background: #101816;
  color: #f7f2e8;
  border-color: #101816;
}

.create-btn.recording {
  background: #e53935;
  color: #fff;
  border-color: #e53935;
  animation: pulse 1.2s infinite;
}

.create-btn.disabled {
  opacity: 0.5;
}

.create-btn-icon {
  width: 36rpx;
  height: 36rpx;
}

.create-btn-icon.white {
  filter: brightness(0) invert(1);
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* 信息卡片 */
.info-card {
  padding: 32rpx;
  background: #fff;
  border-radius: 28rpx;
}

.info-card .field:last-child {
  margin-bottom: 0;
}

.info-card .toggle-row {
  padding: 8rpx 0 0;
  margin-top: 0;
}
