<view class="page my-home-page">
  <custom-nav title="我的主页" showBack="{{true}}" />

  <!-- 顶部资料卡 -->
  <view class="profile-card" style="padding-top: {{heroPaddingTop}}px;">
    <view class="profile-avatar">
      <text class="profile-initial" wx:if="{{!user.avatar}}">{{user.initial}}</text>
      <image wx:else class="profile-avatar-img" src="{{user.avatar}}" mode="aspectFill" />
    </view>
    <text class="profile-name">{{user.nickname || '点击授权'}}</text>
    <text class="profile-remark" wx:if="{{remark}}">{{remark}}</text>
    <view class="profile-edit" bindtap="startEditRemark">{{remark ? '编辑备注' : '添加备注'}}</view>
  </view>

  <!-- 备注编辑表单 -->
  <view class="edit-panel card" wx:if="{{isEditingRemark}}">
    <view class="edit-title">编辑备注</view>
    <textarea
      class="edit-remark"
      value="{{editRemark}}"
      bindinput="onRemarkInput"
      placeholder="写点什么备注，展示给协作伙伴..."
      maxlength="200"
      adjust-position="{{true}}"
    />
    <view class="edit-actions">
      <view class="edit-btn save" bindtap="saveRemark">保存</view>
      <view class="edit-btn cancel" bindtap="cancelEditRemark">取消</view>
    </view>
  </view>

  <!-- 我能提供的服务 -->
  <view class="section card">
    <view class="section-header">
      <text class="section-title">我能提供的服务</text>
      <text class="section-action" bindtap="toggleTagEdit">{{tagEditing ? '完成' : '＋ 添加'}}</text>
    </view>
    <view class="tag-list" wx:if="{{serviceTags.length}}">
      <view class="tag-pill {{tagEditing ? 'editing' : ''}}" wx:for="{{serviceTags}}" wx:key="*this">
        <text class="tag-text">{{item}}</text>
        <text class="tag-remove" wx:if="{{tagEditing}}" bindtap="removeTag" data-index="{{index}}">×</text>
      </view>
    </view>
    <view class="tag-empty" wx:if="{{!serviceTags.length && !tagEditing}}">还没有标签，点击添加，让朋友知道你能帮什么</view>

    <view class="tag-edit-area" wx:if="{{tagEditing}}">
      <input
        class="tag-input"
        value="{{tagInput}}"
        bindinput="onTagInput"
        bindconfirm="addTag"
        placeholder="输入标签，按回车添加"
        confirm-type="done"
      />
      <view class="candidate-tags" wx:if="{{candidateTags.length}}">
        <text class="candidate-label">推荐：</text>
        <text
          class="candidate-tag"
          wx:for="{{candidateTags}}"
          wx:key="*this"
          bindtap="addCandidateTag"
          data-tag="{{item}}"
        >{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 我的记事卡 -->
  <view class="section card">
    <view class="section-header">
      <text class="section-title">我的记事卡</text>
    </view>
    <view class="subtabs">
      <view
        class="subtab {{activeTab === 'mine' ? 'on' : ''}}"
        bindtap="switchTab"
        data-tab="mine"
      >未完成 {{counts.mine}}</view>
      <view
        class="subtab {{activeTab === 'done' ? 'on' : ''}}"
        bindtap="switchTab"
        data-tab="done"
      >已完成 {{counts.done}}</view>
      <view
        class="subtab {{activeTab === 'helped' ? 'on' : ''}}"
        bindtap="switchTab"
        data-tab="helped"
      >我协助的 {{counts.helped}}</view>
    </view>

    <scroll-view class="card-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="card-list" wx:if="{{cards.length}}">
        <view
          wx:for="{{cards}}"
          wx:key="id"
          class="ncard"
          bindtap="openCard"
          data-id="{{item.id}}"
        >
          <text class="ncard-title">{{item.title || '未命名事项'}}</text>
          <view class="ncard-meta">
            <view class="status-pill {{item.statusClass}}">
              <view class="dot"></view>
              <text>{{item.statusText}}</text>
            </view>
            <text class="ncard-when">{{item.whenText}}</text>
          </view>
        </view>
      </view>

      <empty-state wx:if="{{!loading && cards.length === 0}}" title="{{emptyText}}" mode="simple" />

      <view class="content-bottom-space"></view>
    </scroll-view>
  </view>

  <!-- 我的互助数据 -->
  <view class="section card section-last">
    <view class="section-header">
      <text class="section-title">我的互助数据</text>
    </view>
    <view class="stat-row">
      <view class="stat-item">
        <text class="stat-num">{{stats.helperCount}}</text>
        <text class="stat-label">协作过的人</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.helpedCount}}</text>
        <text class="stat-label">被求助次数</text>
      </view>
    </view>
  </view>
</view>
