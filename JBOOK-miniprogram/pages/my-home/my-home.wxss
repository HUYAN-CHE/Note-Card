.my-home-page {
  padding-bottom: 40rpx;
}

/* 顶部资料卡 */
.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 48rpx 40rpx;
  text-align: center;
}

.profile-avatar {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.22);
}

.profile-avatar-img {
  width: 148rpx;
  height: 148rpx;
}

.profile-initial {
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
}

.profile-name {
  margin-top: 24rpx;
  font-size: 40rpx;
  font-weight: 800;
  color: #162116;
}

.profile-remark {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #68705f;
  max-width: 80%;
  line-height: 1.4;
}

.profile-edit {
  margin-top: 20rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #4caf50;
  border: 2rpx solid #4caf50;
  border-radius: 32rpx;
  font-weight: 500;
}

/* 备注编辑 */
.edit-panel {
  margin: 0 28rpx 28rpx;
  padding: 28rpx;
}

.edit-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #162116;
  margin-bottom: 20rpx;
}

.edit-remark {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.edit-actions {
  display: flex;
  justify-content: center;
  margin-top: 28rpx;
  gap: 24rpx;
}

.edit-btn {
  padding: 16rpx 48rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.edit-btn.save {
  color: #fff;
  background: #4caf50;
}

.edit-btn.cancel {
  color: #666;
  background: #f0f0f0;
}

/* 服务标签 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-pill {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #e8f5e9;
  border-radius: 28rpx;
  transition: all 0.2s ease;
}

.tag-pill.editing {
  background: #c8e6c9;
}

.tag-text {
  font-size: 26rpx;
  color: #2e7d32;
}

.tag-remove {
  margin-left: 12rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 50%;
}

.tag-empty {
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 0 16rpx;
}

.tag-edit-area {
  margin-top: 8rpx;
}

.tag-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #333;
}

.candidate-tags {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 14rpx;
}

.candidate-label {
  font-size: 24rpx;
  color: #999;
}

.candidate-tag {
  padding: 8rpx 20rpx;
  background: #f5f7fa;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #4caf50;
  border: 1rpx solid #e8f5e9;
}

/* 子标签 */
.subtabs {
  display: flex;
  gap: 32rpx;
  margin-bottom: 20rpx;
}

.subtab {
  position: relative;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.subtab.on {
  color: #162116;
  font-weight: 700;
}

.subtab.on::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 4rpx;
  background: #4caf50;
  border-radius: 2rpx;
}

/* 卡片列表 */
.card-scroll {
  max-height: 680rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ncard {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
}

.ncard-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
  line-height: 1.4;
}

.ncard-meta {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  gap: 16rpx;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-pill .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.status-pill.doing {
  color: #4caf50;
  background: #e8f5e9;
}

.status-pill.doing .dot {
  background: #4caf50;
}

.status-pill.todo {
  color: #c78000;
  background: #fff8e6;
}

.status-pill.todo .dot {
  background: #ffb300;
}

.status-pill.done {
  color: #888;
  background: #f5f5f5;
}

.status-pill.done .dot {
  background: #bbb;
}

.ncard-when {
  font-size: 24rpx;
  color: #bbb;
}

.content-bottom-space {
  height: 24rpx;
}

/* 互助数据 */
.section-last {
  margin-bottom: 40rpx;
}

.stat-row {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #162116;
  line-height: 1.2;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}
