<view class="page card-detail-page">
  <custom-nav title="记事卡详情" showBack="{{true}}" theme="light" statusBarHeight="{{statusBarHeight}}" navHeight="{{navHeight}}" />

  <!-- 固定背景层：不随内容滚动 -->
  <view class="page-bg"></view>

  <view class="detail-body" style="padding-top: {{totalHeight + 12}}px; padding-bottom: calc(220rpx + {{safeAreaBottom}}px);">

    <!-- 主卡：白色大圆角，浮在薄荷绿背景上；g-card-ticket 带票根缺口 -->
    <view class="g-card g-card-ticket {{developing ? 'developing' : ''}} {{cardReady ? 'card-in' : ''}}">

      <!-- 标题 + 状态胶囊（创立者/共同行动人可点击编辑标题、重点内容） -->
      <view class="dev dev-1 g-head {{canEditStatus ? 'can-edit' : ''}}" bindtap="openEditSheet">
        <text class="g-title">{{displayTitle}}</text>
        <view class="g-status">
          <image class="g-status-icon" src="/assets/icons/clock.svg" mode="aspectFit" />
          <text>{{statusText}}</text>
        </view>
      </view>

      <!-- 共同行动人 -->
      <view class="dev dev-2 g-row-label">
        <view class="g-label g-label-lg">
          <image class="g-label-icon" src="/assets/icons/users.svg" mode="aspectFit" />
          <text>共同行动人</text>
        </view>
        <view class="g-hint g-activity-entry" wx:if="{{isCreator || isHelper}}" bindtap="openActivitySheet" aria-label="协作记录">
          <image class="g-activity-icon" src="/assets/icons/activity.svg" mode="aspectFit" />
          <text>协作记录</text>
        </view>
      </view>
      <view class="dev dev-3 g-avatars-row">
        <view class="g-avatars">
          <!-- 项目圆：有附件取第一张缩略图，无附件显示标题首字；多张带数量角标，点击预览可左右滑 -->
          <view class="g-project" bindtap="onProjectAvatarTap" aria-label="项目图片">
            <view class="g-avatar g-avatar-project">
              <text wx:if="{{!projectThumb}}">{{projectInitial}}</text>
              <image wx:else src="{{projectThumb}}" mode="aspectFill" />
            </view>
            <view class="g-avatar-badge" wx:if="{{attachments.length > 1}}">{{attachments.length}}</view>
          </view>
          <view class="g-avatar">
            <text wx:if="{{!creator.avatar}}">{{creator.initial}}</text>
            <image wx:else src="{{creator.avatar}}" mode="aspectFill" />
          </view>
          <view class="g-link"></view>
          <block wx:if="{{helpers.length}}">
            <view class="g-avatar" wx:for="{{helpers}}" wx:key="id">
              <text wx:if="{{!item.avatar}}">{{item.initial}}</text>
              <image wx:else src="{{item.avatar}}" mode="aspectFill" />
            </view>
          </block>
          <view class="g-avatar g-avatar-empty" wx:else></view>
          <button class="g-avatar g-avatar-add" open-type="share" wx:if="{{isCreator || isHelper}}" aria-label="邀请协作">＋</button>
        </view>
        <button class="g-invite-pill" open-type="share" wx:if="{{isCreator || isHelper}}" data-action="share" aria-label="邀请协作"><image class="g-invite-icon" src="/assets/icons/share-green.svg" mode="aspectFit" />邀请协作</button>
      </view>

      <!-- 需求描述 · 重点（创立者/共同行动人可点击编辑） -->
      <view class="dev dev-4 g-section {{canEditStatus ? 'can-edit' : ''}}" wx:if="{{card.desc || keyPoints.length || canEditStatus}}" bindtap="openEditSheet">
        <view class="g-label g-label-lg">
          <image class="g-label-icon" src="/assets/icons/flag.svg" mode="aspectFit" />
          <text>需求描述 · 重点</text>
        </view>
        <text class="g-desc" wx:if="{{card.desc}}">{{card.desc}}</text>
        <view class="g-tags" wx:if="{{keyPoints.length}}">
          <text class="g-tag" wx:for="{{keyPoints}}" wx:key="*this">{{item}}</text>
        </view>
        <text class="g-desc g-desc-empty" wx:if="{{!card.desc && !keyPoints.length}}">点击补充需求描述与重点</text>
      </view>

      <!-- 当前进度 -->
      <view class="dev dev-5 g-kv-row g-kv-row-lg" bindtap="onStatusTap">
        <view class="g-label g-label-lg">
          <image class="g-label-icon" src="/assets/icons/pulse.svg" mode="aspectFit" />
          <text>当前进度</text>
        </view>
        <view class="g-progress-pill {{canEditStatus ? 'can-pick' : ''}}">
          <text>{{statusText}}</text>
          <text class="g-progress-arrow" wx:if="{{canEditStatus}}">▾</text>
        </view>
      </view>

      <!-- 截止日期（创立者/共同行动人可点击选择） -->
      <view class="dev dev-6 g-kv-row">
        <view class="g-label g-label-lg">
          <image class="g-label-icon" src="/assets/icons/calendar.svg" mode="aspectFit" />
          <text>截止日期</text>
        </view>
        <picker mode="date" value="{{card.deadline}}" bindchange="onDeadlineChange" disabled="{{!canEditStatus}}">
          <view class="g-kv-value {{card.deadline ? (isOverdue ? 'overdue' : '') : 'muted'}}">{{displayDeadline || '点击设置'}}</view>
        </picker>
      </view>

      <!-- 撕裂虚线（票根） -->
      <view class="dev dev-7 g-tearline"></view>

      <!-- CARD ID + 小程序码 -->
      <view class="dev dev-8 g-cardid-row">
        <view class="g-cardid-left" bindtap="onCopyRefCode" data-action="copy-refcode" aria-label="复制 Agent 口令">
          <text class="g-cardid-label">CARD ID</text>
          <text class="g-cardid-code">{{refCode ? '#' + refCode : '# · · ·'}}</text>
          <text class="g-cardid-hint">点击复制 Agent 口令</text>
        </view>
        <image class="g-qrcode" src="{{qrCodeSrc}}" mode="aspectFit" wx:if="{{qrCodeSrc}}" />
        <view class="g-qrcode-placeholder" wx:else>{{refCode || '···'}}</view>
      </view>
    </view>

    <!-- 审批区（仅创作者） -->
    <view class="g-card detail-section" wx:if="{{isCreator && pendingRequests.length}}">
      <view class="g-label">加入申请</view>
      <view class="request-list">
        <view class="request-item" wx:for="{{pendingRequests}}" wx:key="id">
          <view class="request-user">
            <view class="request-avatar">
              <text wx:if="{{!item.avatar}}">{{item.initial}}</text>
              <image wx:else src="{{item.avatar}}" mode="aspectFill" />
            </view>
            <view class="request-info">
              <text class="request-name">{{item.nickname || '未知用户'}}</text>
              <text class="request-note" wx:if="{{item.note}}">{{item.note}}</text>
            </view>
          </view>
          <view class="request-actions">
            <view class="request-btn reject" bindtap="approveRequest" data-id="{{item.id}}" data-approved="{{false}}">拒绝</view>
            <view class="request-btn approve" bindtap="approveRequest" data-id="{{item.id}}" data-approved="{{true}}">通过</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作：位置颜色不变——左浅绿「保存卡片」，右绿「邀请协作」 -->
  <view class="detail-footer" style="padding-bottom: calc(28rpx + {{safeAreaBottom}}px);" wx:if="{{role !== 'stranger' || isNetworkView}}">
    <block wx:if="{{isCreator || isHelper}}">
      <button class="footer-btn ghost" bindtap="onSavePoster" data-action="save-poster" aria-label="保存卡片"><image class="footer-icon" src="/assets/icons/save-green.svg" mode="aspectFit" />保存卡片</button>
      <button class="footer-btn primary" open-type="share" data-action="share" aria-label="邀请协作"><image class="footer-icon" src="/assets/icons/share-white.svg" mode="aspectFit" />邀请协作</button>
    </block>
    <button class="footer-btn primary wide" wx:if="{{isNetworkView}}" bindtap="openApplySheet">申请加入</button>
    <button class="footer-btn primary wide" wx:if="{{canAcceptInvite}}" bindtap="acceptInvite">接受邀请</button>
  </view>

  <!-- 申请加入 Sheet -->
  <bottom-sheet visible="{{showApplySheet}}" title="申请加入" subtitle="填写说明，让创立者了解你能帮上什么" safeAreaBottom="{{safeAreaBottom}}" bind:close="closeApplySheet">
    <view class="apply-body">
      <textarea
        class="apply-input"
        value="{{applyMessage}}"
        bindinput="onApplyInput"
        placeholder="例如：我周六有空，可以开车接送..."
        maxlength="200"
        adjust-position="{{true}}"
      />
      <view class="sheet-actions">
        <button class="sheet-btn ghost" bindtap="closeApplySheet">取消</button>
        <button class="sheet-btn primary" bindtap="submitApply">提交申请</button>
      </view>
    </view>
  </bottom-sheet>

  <!-- 编辑卡片 Sheet（创立者/共同行动人） -->
  <bottom-sheet visible="{{showEditSheet}}" title="编辑记事卡" subtitle="标题、需求描述与重点内容" safeAreaBottom="{{safeAreaBottom}}" bind:close="closeEditSheet">
    <view class="edit-body">
      <view class="edit-field">
        <text class="edit-label">标题</text>
        <input class="edit-input" value="{{editForm.title}}" bindinput="onEditTitleInput" placeholder="如 周六拼车去露营" placeholder-class="edit-ph" maxlength="30" />
      </view>
      <view class="edit-field">
        <text class="edit-label">需求描述</text>
        <textarea class="edit-textarea" value="{{editForm.desc}}" bindinput="onEditDescInput" placeholder="描述一下需要帮忙的事" placeholder-class="edit-ph" maxlength="500" adjust-position="{{true}}" />
      </view>
      <view class="edit-field">
        <view class="edit-label">重点<text class="edit-label-hint">用 · 分隔</text></view>
        <input class="edit-input" value="{{editForm.keyPointsText}}" bindinput="onEditKeyPointsInput" placeholder="时间 · 地点 · 分工" placeholder-class="edit-ph" maxlength="200" />
      </view>
      <view class="sheet-actions">
        <button class="sheet-btn ghost" bindtap="closeEditSheet">取消</button>
        <button class="sheet-btn primary" bindtap="submitEdit">保存</button>
      </view>
    </view>
  </bottom-sheet>

  <!-- 协作记录 Sheet -->
  <bottom-sheet visible="{{showActivitySheet}}" title="协作记录" subtitle="共同行动人的最近操作" safeAreaBottom="{{safeAreaBottom}}" bind:close="closeActivitySheet">
    <view class="activity-body">
      <view class="activity-empty" wx:if="{{!activitiesLoading && !activities.length}}">暂无协作记录</view>
      <view class="activity-empty" wx:if="{{activitiesLoading}}">加载中...</view>
      <view class="activity-item" wx:for="{{activities}}" wx:key="id">
        <view class="activity-avatar">
          <text wx:if="{{!item.actorAvatar}}">{{item.actorInitial}}</text>
          <image wx:else src="{{item.actorAvatar}}" mode="aspectFill" />
        </view>
        <view class="activity-info">
          <text class="activity-text"><text class="activity-name">{{item.actorName}}</text> {{item.detail}}</text>
          <text class="activity-time">{{item.timeText}}</text>
        </view>
      </view>
    </view>
  </bottom-sheet>

  <!-- 海报画布（离屏渲染，保存卡片时使用） -->
  <canvas type="2d" id="posterCanvas" class="poster-canvas"></canvas>
</view>
