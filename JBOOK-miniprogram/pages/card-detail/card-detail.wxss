/* 深色摄影棚背景：让白色相纸成为唯一主角 */
page {
  background: #1b221e;
}

.card-detail-page {
  padding: 0;
  min-height: 100vh;
  background: linear-gradient(170deg, #232b26 0%, #1b221e 52%, #151a17 100%);
}

.detail-body {
  position: relative;
  z-index: 1;
}

/* ==================== 机器头 + 出卡口（固定不动） ==================== */

/* 机器头：压在内容上方的固定台面，内容滚动时从它下缘滑入滑出 */
.eject-head {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 90;
  background: linear-gradient(180deg, #28312b 0%, #222a25 100%);
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.35);
}

/* 出卡口：嵌在机器头下缘的窄缝 */
.eject-slot {
  position: fixed;
  left: 44rpx;
  right: 44rpx;
  height: 12rpx;
  z-index: 91;
  border-radius: 999rpx;
  background: linear-gradient(
    180deg,
    #0a1e11 0%,
    #1a4a2a 48%,
    #0a1e11 100%
  );
  box-shadow:
    inset 0 2rpx 4rpx rgba(0, 0, 0, 0.65),
    0 3rpx 8rpx rgba(0, 0, 0, 0.4);
}

.photo-clip {
  position: relative;
  z-index: 2;
  overflow: hidden;
}

/* 拍立得相纸：挺括白边框、底部厚白边 */
.photo {
  margin: 16rpx 44rpx 0;
  padding: 28rpx 28rpx 0;
  background: #ffffff;
  border-radius: 6rpx;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.45);
}

/* 药膜内区：浅灰绿底、细内描边 */
.photo-film {
  padding: 36rpx 30rpx;
  background: #edf1e9;
  border-radius: 3rpx;
  box-shadow: inset 0 0 0 1rpx rgba(21, 71, 40, 0.05);
}

/* 区块：无分隔线，靠留白分段 */
.film-section {
  margin-top: 42rpx;
}

/* 博物馆标签式小标题 */
.film-label {
  margin-bottom: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: #7d887b;
}

/* 相纸下白边：编号区 */
.photo-ref {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0 34rpx;
}

.photo-ref-code {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #22301f;
  font-family: 'Courier New', Courier, monospace;
}

.photo-ref-hint {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #a9b3a6;
}

/* ==================== 出片 + 显影动画 ==================== */

/* 非生成路径：相纸直接淡入 */
.photo-in {
  animation: photo-fade 0.35s ease both;
}

@keyframes photo-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 生成路径：相纸从出卡口滑出 */
.developing .photo-in {
  animation: photo-eject 0.8s cubic-bezier(0.22, 0.9, 0.3, 1) both;
}

@keyframes photo-eject {
  0% { transform: translateY(-103%); }
  100% { transform: translateY(0); }
}

/* 显影：内容从模糊低对比渐次清晰 */
.developing .dev {
  animation: dev-in 1.1s ease-out both;
}

.developing .dev-1 { animation-delay: 0.9s; }
.developing .dev-2 { animation-delay: 1.15s; }
.developing .dev-3 { animation-delay: 1.4s; }
.developing .dev-4 { animation-delay: 1.65s; }
.developing .dev-5 { animation-delay: 1.9s; }
.developing .dev-6 { animation-delay: 2.15s; }
.developing .dev-7 { animation-delay: 2.5s; }

@keyframes dev-in {
  0% {
    opacity: 0;
    filter: blur(5px) brightness(1.25);
  }
  55% {
    opacity: 0.75;
    filter: blur(1.5px) brightness(1.08);
  }
  100% {
    opacity: 1;
    filter: blur(0) brightness(1);
  }
}

/* ==================== 卡内内容 ==================== */

.detail-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #162116;
  line-height: 1.35;
}

.creator {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
}

.creator-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.creator-avatar image {
  width: 72rpx;
  height: 72rpx;
}

.creator-info {
  display: flex;
  flex-direction: column;
  margin-left: 18rpx;
}

.creator-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
}

.creator-relation {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #68705f;
}

.detail-summary {
  font-size: 28rpx;
  color: #4a5347;
  line-height: 1.75;
}

/* 审批区（相纸外，白卡贴在深色背景上） */
.detail-section {
  margin: 32rpx 44rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.3);
}

.detail-section .film-label {
  color: #8a948a;
}

/* 共同行动人 */
.helpers {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.helper {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(21, 71, 40, 0.08);
}

.helper-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.helper-avatar image {
  width: 48rpx;
  height: 48rpx;
}

.helper-name {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.helper-add {
  border: 2rpx dashed #4caf50;
  background: rgba(76, 175, 80, 0.06);
  box-shadow: none;
}

.helper-add-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 32rpx;
  color: #4caf50;
}

.helpers-empty {
  font-size: 28rpx;
  color: #999;
}

/* 重点 / 待确认 */
.keypoints {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.keypoint {
  padding: 10rpx 22rpx;
  background: #fff8e6;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #c78000;
}

/* 当前进度 KV：去底色，只留发丝分隔线 */
.kv-list {
  padding: 0;
}

.kv-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(22, 33, 22, 0.08);
}

.kv-item:last-child {
  border-bottom: none;
}

.kv-key {
  font-size: 28rpx;
  color: #888;
}

.kv-value {
  font-size: 28rpx;
  color: #162116;
  font-weight: 500;
}

.kv-value.doing {
  color: #4caf50;
}

.kv-value.todo {
  color: #c78000;
}

.kv-value.done {
  color: #888;
}

.kv-value.muted {
  color: #bbb;
}

.kv-value.overdue {
  color: #e53935;
}

/* 状态选择：胶囊样式，可点击时带下拉箭头与描边 */
.status-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #f0f0f0;
  color: #888;
}

.status-picker.todo {
  background: #fff4e0;
  color: #c78000;
}

.status-picker.doing {
  background: #e8f5e9;
  color: #43a047;
}

.status-picker.done {
  background: #f0f0f0;
  color: #888;
}

.status-picker.can-pick {
  box-shadow: inset 0 0 0 2rpx currentColor;
  opacity: 0.95;
}

.status-picker-arrow {
  font-size: 22rpx;
}

/* 审批列表 */
.request-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.request-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.request-user {
  display: flex;
  align-items: flex-start;
}

.request-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.request-avatar image {
  width: 56rpx;
  height: 56rpx;
}

.request-info {
  margin-left: 16rpx;
  flex: 1;
  min-width: 0;
}

.request-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #162116;
}

.request-note {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #68705f;
  line-height: 1.4;
}

.request-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.request-btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.request-btn.approve {
  color: #fff;
  background: #4caf50;
}

.request-btn.reject {
  color: #666;
  background: #f0f0f0;
}

/* ==================== 底部操作（深色） ==================== */

.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: rgba(18, 23, 20, 0.92);
  backdrop-filter: blur(16rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  z-index: 50;
}

.footer-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.footer-btn::after {
  display: none;
}

.footer-btn.primary {
  background: #4caf50;
  color: #fff;
}

.footer-btn.ghost {
  background: rgba(255, 255, 255, 0.12);
  color: #e8ede9;
}

.footer-btn[disabled] {
  background: rgba(255, 255, 255, 0.08);
  color: #777;
}

/* 申请 Sheet */
.apply-body {
  padding-top: 8rpx;
}

.apply-input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.sheet-btn::after {
  display: none;
}

.sheet-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.sheet-btn.primary {
  color: #fff;
  background: #4caf50;
}

/* 海报画布：离屏放置，不参与布局 */
.poster-canvas {
  position: fixed;
  left: -2200px;
  top: 0;
  width: 750px;
  height: 1120px;
}
