.card-detail-page {
  padding-top: 0;
  padding-bottom: 160rpx;
}

/* 顶部标题与创立者 */
.detail-hero {
  margin: 0 28rpx 32rpx;
  padding: 36rpx 32rpx;
  background: linear-gradient(150deg, #e8f5e9, #c8e6c9);
  border-radius: 28rpx;
}

.detail-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #162116;
  line-height: 1.4;
}

.creator {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
}

.creator-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.creator-avatar image {
  width: 72rpx;
  height: 72rpx;
}

.creator-info {
  display: flex;
  flex-direction: column;
  margin-left: 18rpx;
}

.creator-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
}

.creator-relation {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #68705f;
}

/* 区块 */
.detail-section {
  margin: 0 28rpx 28rpx;
  padding: 28rpx;
}

.detail-section .section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #162116;
  margin-bottom: 18rpx;
}

.detail-summary {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* 协助者 */
.helpers {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.helper {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background: #f8f9fa;
  border-radius: 40rpx;
}

.helper-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.helper-avatar image {
  width: 48rpx;
  height: 48rpx;
}

.helper-name {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.helper-add {
  border: 2rpx dashed #4caf50;
  background: rgba(76, 175, 80, 0.06);
}

.helper-add-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 32rpx;
  color: #4caf50;
}

.helpers-empty {
  font-size: 28rpx;
  color: #999;
}

/* 重点 / 待确认 */
.keypoints {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.keypoint {
  padding: 10rpx 22rpx;
  background: #fff8e6;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #c78000;
}

/* 当前进度 KV */
.kv-list {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
}

.kv-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.kv-item:last-child {
  border-bottom: none;
}

.kv-key {
  font-size: 28rpx;
  color: #888;
}

.kv-value {
  font-size: 28rpx;
  color: #162116;
  font-weight: 500;
}

.kv-value.doing {
  color: #4caf50;
}

.kv-value.todo {
  color: #c78000;
}

.kv-value.done {
  color: #888;
}

.kv-value.muted {
  color: #bbb;
}

/* 审批列表 */
.request-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.request-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.request-user {
  display: flex;
  align-items: flex-start;
}

.request-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.request-avatar image {
  width: 56rpx;
  height: 56rpx;
}

.request-info {
  margin-left: 16rpx;
  flex: 1;
  min-width: 0;
}

.request-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #162116;
}

.request-note {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #68705f;
  line-height: 1.4;
}

.request-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.request-btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.request-btn.approve {
  color: #fff;
  background: #4caf50;
}

.request-btn.reject {
  color: #666;
  background: #f0f0f0;
}

/* 底部 */
.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 50;
}

.footer-row {
  display: flex;
  gap: 20rpx;
}

.footer-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.footer-btn::after {
  display: none;
}

.footer-btn.primary {
  background: #4caf50;
  color: #fff;
}

.footer-btn.ghost {
  background: #f0f0f0;
  color: #666;
}

.footer-btn[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* 申请 Sheet */
.apply-body {
  padding-top: 8rpx;
}

.apply-input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.sheet-btn::after {
  display: none;
}

.sheet-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.sheet-btn.primary {
  color: #fff;
  background: #4caf50;
}
