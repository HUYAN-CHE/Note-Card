.card-detail-page {
  padding-top: 0;
  padding-bottom: 0;
}

/* 记事卡：一整张收据式卡片，顶部直角，深绿色上投影 */
.receipt-card {
  margin: 0 28rpx;
  padding: 36rpx 32rpx 32rpx;
  background: #ffffff;
  border-radius: 0;
  box-shadow:
    0 -12rpx 28rpx rgba(21, 71, 40, 0.35),
    0 12rpx 32rpx rgba(0, 0, 0, 0.06);
}

/* 绿色头部背景：向下渐隐融入页面，无圆角 */
.detail-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: linear-gradient(
    180deg,
    #5cb860 0%,
    #4caf50 45%,
    rgba(76, 175, 80, 0.6) 70%,
    rgba(76, 175, 80, 0) 100%
  );
  z-index: 0;
}

.detail-body {
  position: relative;
  z-index: 1;
}

/* 出卡辊筒：圆柱体，上暗下亮圆柱阴影，下半被白卡遮挡 */
.card-slot {
  position: absolute;
  z-index: 1;
  left: 20rpx;
  right: 20rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(
    180deg,
    #0e2f19 0%,
    #1f5c30 42%,
    #143d22 100%
  );
  box-shadow: 0 -6rpx 14rpx rgba(14, 47, 25, 0.4);
}

/* 打印出口：卡片从头部下方向下打出，顶部留白给卡的上投影 */
.receipt-clip {
  position: relative;
  z-index: 2;
  overflow: hidden;
  padding-top: 40rpx;
  padding-bottom: 8rpx;
}

.receipt-inner.print-in {
  animation: receipt-print 0.8s cubic-bezier(0.22, 0.9, 0.3, 1) both;
}

@keyframes receipt-print {
  0% {
    transform: translateY(-104%);
  }
  100% {
    transform: translateY(0);
  }
}

/* 收据圆波浪锯齿边 */
.rc-zigzag {
  margin: 0 28rpx 32rpx;
  height: 20rpx;
  background-image: radial-gradient(circle at 20rpx 0, #ffffff 16rpx, rgba(0, 0, 0, 0) 17rpx);
  background-size: 40rpx 20rpx;
  background-repeat: repeat-x;
}

/* 卡内分区块与虚线分隔 */
.rc-section .section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #162116;
  margin-bottom: 18rpx;
}

.rc-divider {
  border-top: 2rpx dashed #e8e8e8;
  margin: 28rpx 0;
}

.detail-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #162116;
  line-height: 1.4;
}

.creator {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
}

.creator-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.creator-avatar image {
  width: 72rpx;
  height: 72rpx;
}

.creator-info {
  display: flex;
  flex-direction: column;
  margin-left: 18rpx;
}

.creator-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #162116;
}

.creator-relation {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #68705f;
}

/* 区块 */
.detail-section {
  margin: 0 28rpx 28rpx;
  padding: 28rpx;
}

.detail-section .section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #162116;
  margin-bottom: 18rpx;
}

.detail-summary {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* 共同行动人 */
.helpers {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.helper {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background: #f8f9fa;
  border-radius: 40rpx;
}

.helper-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}

.helper-avatar image {
  width: 48rpx;
  height: 48rpx;
}

.helper-name {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.helper-add {
  border: 2rpx dashed #4caf50;
  background: rgba(76, 175, 80, 0.06);
}

.helper-add-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 32rpx;
  color: #4caf50;
}

.helpers-empty {
  font-size: 28rpx;
  color: #999;
}

/* 重点 / 待确认 */
.keypoints {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.keypoint {
  padding: 10rpx 22rpx;
  background: #fff8e6;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #c78000;
}

/* 当前进度 KV */
.kv-list {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
}

.kv-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.kv-item:last-child {
  border-bottom: none;
}

.kv-key {
  font-size: 28rpx;
  color: #888;
}

.kv-value {
  font-size: 28rpx;
  color: #162116;
  font-weight: 500;
}

.kv-value.doing {
  color: #4caf50;
}

.kv-value.todo {
  color: #c78000;
}

.kv-value.done {
  color: #888;
}

.kv-value.muted {
  color: #bbb;
}

.kv-value.overdue {
  color: #e53935;
}

/* 状态选择：胶囊样式，可点击时带下拉箭头与虚线描边 */
.status-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #f0f0f0;
  color: #888;
}

.status-picker.todo {
  background: #fff4e0;
  color: #c78000;
}

.status-picker.doing {
  background: #e8f5e9;
  color: #43a047;
}

.status-picker.done {
  background: #f0f0f0;
  color: #888;
}

.status-picker.can-pick {
  box-shadow: inset 0 0 0 2rpx currentColor;
  opacity: 0.95;
}

.status-picker-arrow {
  font-size: 22rpx;
}

/* 审批列表 */
.request-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.request-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.request-user {
  display: flex;
  align-items: flex-start;
}

.request-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.request-avatar image {
  width: 56rpx;
  height: 56rpx;
}

.request-info {
  margin-left: 16rpx;
  flex: 1;
  min-width: 0;
}

.request-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #162116;
}

.request-note {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #68705f;
  line-height: 1.4;
}

.request-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.request-btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.request-btn.approve {
  color: #fff;
  background: #4caf50;
}

.request-btn.reject {
  color: #666;
  background: #f0f0f0;
}

/* 底部 */
.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.03);
  z-index: 50;
}

.footer-row {
  display: flex;
  gap: 20rpx;
}

.footer-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.footer-btn::after {
  display: none;
}

.footer-btn.primary {
  background: #4caf50;
  color: #fff;
}

.footer-btn.ghost {
  background: #f0f0f0;
  color: #666;
}

.footer-btn[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* 申请 Sheet */
.apply-body {
  padding-top: 8rpx;
}

.apply-input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.sheet-btn::after {
  display: none;
}

.sheet-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.sheet-btn.primary {
  color: #fff;
  background: #4caf50;
}

/* 滑动邀请共同行动人 */
.swipe-invite {
  position: relative;
  height: 96rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e9f7ee 0%, #d8f1e0 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.swipe-invite.done {
  background: linear-gradient(135deg, #d4f0dc 0%, #c4ead1 100%);
}

.swipe-hint {
  font-size: 28rpx;
  font-weight: 600;
  color: #3d8a52;
  letter-spacing: 2rpx;
}

.swipe-knob {
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #4caf50;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.35);
  transition: transform 0.25s ease;
}

.swipe-invite.swiping .swipe-knob {
  transition: none;
}

.swipe-invite.done .swipe-knob {
  background: #43a047;
}

.swipe-knob-icon {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  animation: swipe-arrow-nudge 1.4s ease-in-out infinite;
}

.swipe-invite.swiping .swipe-knob-icon,
.swipe-invite.done .swipe-knob-icon {
  animation: none;
}

@keyframes swipe-arrow-nudge {
  0%, 100% { transform: translateX(0); opacity: 1; }
  50% { transform: translateX(8rpx); opacity: 0.7; }
}
