/* 页面画布铺底色防露底；渐变画在固定层上 */
page {
  background: #f9fcf9;
}

/* 固定背景层：position fixed 不随内容滚动 */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  pointer-events: none;
  background: linear-gradient(180deg, #7ebc8a 0%, #91c79c 28%, #d0e7d6 55%, #f7faf8 78%, #f9fcf9 100%);
}

.card-detail-page {
  padding: 0;
  min-height: 100vh;
}

.detail-body {
  position: relative;
  z-index: 1;
}

/* ==================== 主卡 ==================== */

/* 实测：卡片左右边距 48rpx，圆角 24rpx，卡内左右 padding 24rpx */
.g-card {
  position: relative;
  margin: 20rpx 48rpx 0;
  padding: 64rpx 36rpx 48rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 24rpx 60rpx rgba(46, 125, 78, 0.12);
}

/* 票根缺口：mask 在卡片两端各镂空一个半圆（距卡底 212rpx，与撕裂线同位），
   镂空处透出真实页面背景，不贴图、无近似色 */
.g-card-ticket {
  -webkit-mask-image:
    radial-gradient(circle 20rpx at 0 calc(100% - 220rpx), transparent 19rpx, #000 16rpx),
    radial-gradient(circle 20rpx at 100% calc(100% - 220rpx), transparent 19rpx, #000 16rpx);
  -webkit-mask-composite: destination-in;
  mask-image:
    radial-gradient(circle 20rpx at 0 calc(100% - 220rpx), transparent 19rpx, #000 16rpx),
    radial-gradient(circle 20rpx at 100% calc(100% - 220rpx), transparent 19rpx, #000 16rpx);
  mask-composite: intersect;
}

/* 标题行：标题 + 状态胶囊（标题实测 48rpx） */
.g-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.g-title {
  flex: 1;
  min-width: 0;
  font-size: 48rpx;
  font-weight: 700;
  color: #1a2b1e;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 状态胶囊：实测背景 #eef6f0 极浅绿，文字 #49854f */
.g-status {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: 16rpx;
  margin-top: 10rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: #eef6f0;
  color: #49854f;
}

.g-status-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

/* 行标签：实测字号 24rpx */
.g-row-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #dce8de;
}

.g-label {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #26392c;
}

.g-label-icon {
  width: 26rpx;
  height: 26rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

/* 大号行标签（重点/当前进度/截止日期） */
.g-label-lg {
  font-size: 28rpx;
}

.g-label-lg .g-label-icon {
  width: 32rpx;
  height: 32rpx;
}

.g-hint {
  font-size: 22rpx;
  color: #9aa79c;
  text-align: right;
}

/* 头像链：creator --link-- helpers -- 空位 -- 加号 */
.g-avatars-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
}

.g-avatars {
  display: flex;
  align-items: center;
  min-width: 0;
}

.g-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
  padding: 0;
}

.g-avatar image {
  width: 56rpx;
  height: 56rpx;
}

.g-avatar + .g-avatar {
  margin-left: 10rpx;
}

.g-avatar-empty {
  background: #e6ece7;
}

.g-avatar-add {
  flex: 0 0 56rpx;
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  margin-left: 10rpx;
  background: transparent;
  border: 2rpx dashed #7fb98f;
  color: #49854f;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 52rpx;
}

.g-avatar-add::after {
  display: none;
}

/* 链接符：两个交叠小圆环 */
.g-link {
  position: relative;
  width: 28rpx;
  height: 16rpx;
  margin: 0 8rpx;
  flex-shrink: 0;
}

.g-link::before,
.g-link::after {
  content: '';
  position: absolute;
  top: 2rpx;
  width: 15rpx;
  height: 9rpx;
  border: 2rpx solid #b9c6bc;
  border-radius: 999rpx;
  transform: rotate(-30deg);
}

.g-link::before {
  left: 0;
}

.g-link::after {
  right: 0;
}

/* 卡内邀请协作小胶囊：实测背景 #e3f0e4，文字 #49854f */
.g-invite-pill {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  margin-left: 16rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #e3f0e4;
  color: #49854f;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
}

.g-invite-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.g-invite-pill::after {
  display: none;
}

/* 重点 / 待确认：顶部分割线②（共同行动人|重点） */
.g-section {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #dce8de;
}

/* 正文：实测字号约 22rpx，行高约 1.7 */
.g-desc {
  display: block;
  margin-top: 22rpx;
  font-size: 22rpx;
  color: #8a938c;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* 标签：实测背景 #eef8f0，文字 #49854f，高约 38rpx */
.g-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 28rpx;
}

.g-tag {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  background: #eef8f0;
  color: #49854f;
  font-size: 22rpx;
  font-weight: 500;
}

/* KV 行：实测进度→截止间距约 34rpx */
.g-kv-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 36rpx;
}

/* 当前进度行：顶部分割线③（重点|当前进度） */
.g-kv-row-lg {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #dce8de;
}

.g-kv-value {
  font-size: 26rpx;
  color: #26392c;
  font-weight: 500;
}

.g-kv-value.muted {
  color: #b9c6bc;
}

.g-kv-value.overdue {
  color: #e53935;
}

/* 进度选择胶囊：白底浅绿描边，统一绿色 */
.g-progress-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid #d5e5d9;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  color: #49854f;
}

.g-progress-pill.can-pick {
  box-shadow: 0 2rpx 8rpx rgba(46, 125, 78, 0.1);
}

.g-progress-arrow {
  font-size: 28rpx;
}

/* 撕裂虚线（票根）：虚线中心与 mask 孔中心严格对齐（距卡底 220rpx） */
.g-tearline {
  position: absolute;
  left: -36rpx;
  right: -36rpx;
  bottom: 218rpx;
  border-top: 4rpx dotted #a9bdae;
}

/* CARD ID 区（撕裂线不占文档流，间距在此补齐） */
.g-cardid-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 80rpx;
}

.g-cardid-left {
  display: flex;
  flex-direction: column;
}

.g-cardid-label {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: #a9b5ab;
}

.g-cardid-code {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #49854f;
  font-family: 'Courier New', Courier, monospace;
}

.g-cardid-hint {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #a9b5ab;
}

/* 二维码：实测约 140rpx */
.g-qrcode {
  width: 140rpx;
  height: 140rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.g-qrcode-placeholder {
  width: 140rpx;
  height: 140rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
  border: 2rpx dashed #b9d6c2;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #49854f;
  font-family: 'Courier New', Courier, monospace;
}

/* ==================== 显影动画 ==================== */

.card-in {
  animation: card-fade 0.35s ease both;
}

@keyframes card-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 生成路径：卡片快速上浮 + 内容分段浮现（全程 ≤0.5s，无滤镜避免 iOS 残留） */
.developing.card-in {
  animation: card-rise 0.35s cubic-bezier(0.22, 0.9, 0.3, 1) both;
}

@keyframes card-rise {
  0% {
    opacity: 0;
    transform: translateY(24rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 分段浮现：纯透明度+微位移，最后一段 0.21+0.25=0.46s 结束 */
.developing .dev {
  animation: dev-in 0.25s ease-out both;
}

.developing .dev-1 { animation-delay: 0s; }
.developing .dev-2 { animation-delay: 0.03s; }
.developing .dev-3 { animation-delay: 0.06s; }
.developing .dev-4 { animation-delay: 0.09s; }
.developing .dev-5 { animation-delay: 0.12s; }
.developing .dev-6 { animation-delay: 0.15s; }
.developing .dev-7 { animation-delay: 0.18s; }
.developing .dev-8 { animation-delay: 0.21s; }

@keyframes dev-in {
  0% {
    opacity: 0;
    transform: translateY(8rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ==================== 审批区 ==================== */

.detail-section {
  margin: 28rpx 48rpx;
}

.detail-section .g-label {
  display: block;
  margin-bottom: 20rpx;
}

.request-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.request-item {
  padding: 20rpx;
  background: #f4f8f5;
  border-radius: 20rpx;
}

.request-user {
  display: flex;
  align-items: flex-start;
}

.request-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(150deg, #4caf50, #81c784);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.request-avatar image {
  width: 56rpx;
  height: 56rpx;
}

.request-info {
  margin-left: 16rpx;
  flex: 1;
  min-width: 0;
}

.request-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a2b1e;
}

.request-note {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a938c;
  line-height: 1.4;
}

.request-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.request-btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.request-btn.approve {
  color: #fff;
  background: #77b882;
}

.request-btn.reject {
  color: #666;
  background: #eeeeee;
}

/* ==================== 底部操作（悬浮无底栏，实测高 112rpx） ==================== */

.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 28rpx;
  padding: 0 48rpx;
  z-index: 50;
}

.footer-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 112rpx;
  border-radius: 16rpx;
  border: none;
  font-size: 26rpx;
  font-weight: 600;
}

.footer-btn::after {
  display: none;
}

.footer-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
}

/* 左：实测浅绿 #ecf5ed（保存卡片） */
.footer-btn.ghost {
  background: #ecf5ed;
  color: #49854f;
  box-shadow: 0 10rpx 28rpx rgba(46, 125, 78, 0.16);
}

/* 右：实测绿 #77b882（邀请协作） */
.footer-btn.primary {
  background: #77b882;
  color: #fff;
  box-shadow: 0 10rpx 28rpx rgba(46, 125, 78, 0.3);
}

.footer-btn.wide {
  width: 100%;
}

.footer-btn[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* 申请 Sheet */
.apply-body {
  padding-top: 8rpx;
}

.apply-input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.sheet-btn::after {
  display: none;
}

.sheet-btn.ghost {
  color: #666;
  background: #f0f0f0;
}

.sheet-btn.primary {
  color: #fff;
  background: #77b882;
}

/* 海报画布：离屏放置，不参与布局 */
.poster-canvas {
  position: fixed;
  left: -2200px;
  top: 0;
  width: 750px;
  height: 1120px;
}

/* 协作记录入口：替换原「点击下方分享邀请」提示位 */
.g-activity-entry {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #49854f;
}

.g-activity-icon {
  width: 24rpx;
  height: 24rpx;
}

.g-desc-empty {
  color: #49854f;
}

/* 编辑 Sheet */
.edit-body {
  padding-top: 8rpx;
}

.edit-field {
  margin-bottom: 24rpx;
}

.edit-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #5a6355;
  margin-bottom: 12rpx;
}

.edit-label-hint {
  margin-left: 12rpx;
  font-size: 22rpx;
  font-weight: 400;
  color: #999;
}

.edit-ph {
  color: #999;
}

.edit-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
}

.edit-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

/* 协作记录 Sheet */
.activity-body {
  padding-top: 8rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.activity-empty {
  padding: 48rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #9aa79c;
}

.activity-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2ee;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e8f0e7;
  color: #49854f;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.activity-avatar image {
  width: 100%;
  height: 100%;
}

.activity-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.activity-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
}

.activity-name {
  font-weight: 600;
  color: #1a2b1e;
}

.activity-time {
  font-size: 22rpx;
  color: #9aa79c;
}
