.card-import-page {
  padding-bottom: 160rpx;
}

.content {
  padding: 0 28rpx;
}

.nav-action {
  font-size: 28rpx;
  color: #4caf50;
  font-weight: 600;
}

/* 隐私声明 */
.privacy-notice {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  background: #fff8e6;
  border-radius: 16rpx;
}

.privacy-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.privacy-text {
  flex: 1;
  font-size: 24rpx;
  color: #887020;
  line-height: 1.5;
}

/* 来源标签 */
.src-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 10rpx 20rpx;
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 999rpx;
}

/* 类型选择 */
.type-section {
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.section-label {
  font-size: 26rpx;
  color: #68705f;
  margin-bottom: 16rpx;
}

.type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-item {
  padding: 14rpx 24rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 26rpx;
  border-radius: 999rpx;
  border: 2rpx solid transparent;
}

.type-item.active {
  background: #e8f5e9;
  color: #2e7d32;
  border-color: #4caf50;
}

/* 输入区 */
.field {
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.field-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #162116;
  margin-bottom: 16rpx;
}

.field-textarea,
.imp-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.input-action {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 26rpx;
  border-radius: 12rpx;
}

.file-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.file-pill {
  padding: 8rpx 16rpx;
  background: #e0f2fe;
  color: #0369a1;
  font-size: 24rpx;
  border-radius: 999rpx;
}

/* 预览区 */
.preview-section {
  margin-bottom: 24rpx;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #162116;
}

.preview-regen {
  font-size: 26rpx;
  color: #4caf50;
}

.imp-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(22, 33, 22, 0.08);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.imp-card.off {
  opacity: 0.45;
}

.imp-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 4rpx solid #d1d5db;
  display: grid;
  place-items: center;
  color: transparent;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.imp-check.on {
  background: #4caf50;
  border-color: #4caf50;
  color: #fff;
}

.imp-body {
  flex: 1;
  min-width: 0;
}

.imp-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #162116;
  margin-bottom: 12rpx;
}

.imp-ai {
  font-size: 20rpx;
  background: #e8f5e9;
  color: #2e7d32;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  margin-left: 8rpx;
  font-weight: 400;
}

.imp-input,
.imp-textarea {
  width: 100%;
  padding: 12rpx 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.imp-input {
  height: 76rpx;
}

.bottom-note {
  text-align: center;
  font-size: 22rpx;
  color: #9ca3af;
  margin: 24rpx 0;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 50;
}

.footer-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.footer-btn::after {
  display: none;
}

.footer-btn.primary {
  background: #4caf50;
  color: #fff;
}
