<view class="tab-bar" style="bottom: calc(24rpx + env(safe-area-inset-bottom));">
  <view
    class="tab-item {{activeTab === 'home' ? 'active' : ''}}"
    bindtap="switchTab"
    data-tab="home"
    data-action="switch_tab_home"
    aria-label="事项"
  >
    <view class="tab-icon tab-icon-home menu-icon">
      <view class="menu-line"></view>
      <view class="menu-line"></view>
      <view class="menu-line"></view>
    </view>
    <text class="tab-label">事项</text>
  </view>
  <view
    class="tab-item {{activeTab === 'mutual-help' ? 'active' : ''}}"
    bindtap="switchTab"
    data-tab="mutual-help"
    data-action="switch_tab_mutual_help"
    aria-label="互助"
  >
    <view class="tab-icon mutual-icon">
      <view class="mutual-ring"></view>
    </view>
    <text class="tab-label">互助</text>
  </view>
</view>
