.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-state-simple {
  padding: 120rpx 48rpx;
}

.empty-image {
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #162116;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.empty-state-simple .empty-title {
  font-size: 26rpx;
  font-weight: 400;
  color: #9baaa3;
  margin-bottom: 0;
}

.empty-subtitle {
  font-size: 26rpx;
  color: #68705f;
  line-height: 1.5;
}
