<view class="pull-create-trigger">
  <view class="pull-hero" style="padding-top: {{statusBarHeight}}px;" catchtouchmove="onHeroTouchMove">
    <view class="hero-nav">
      <text class="hero-nav-title">This week</text>
    </view>

    <view class="week-strip">
      <view class="selection-frame"></view>
      <view
        class="week-track"
        style="transform: translate3d({{trackX}}vw, 0, 0); {{isSnapping ? 'transition: transform 200ms ease-out;' : ''}}"
        bindtouchstart="onStripTouchStart"
        bindtouchmove="onStripTouchMove"
        bindtouchend="onStripTouchEnd"
        bindtouchcancel="onStripTouchEnd"
      >
        <view
          wx:for="{{calendarItems}}"
          wx:key="id"
          class="day-slot {{item.isToday ? 'today' : ''}} {{item.active ? 'active' : ''}}"
        >
          <view
            wx:if="{{!item.spacer}}"
            class="day-item"
            data-index="{{item.dateIndex}}"
            bindtap="onCalendarTap"
          >
            <text class="day-label">{{item.label}}</text>
            <text class="day-date">{{item.date}}</text>
            <text wx:if="{{item.active}}" class="day-dot"></text>
          </view>
        </view>
      </view>
    </view>

    <view class="hero-title">{{title}}</view>

    <view class="capsule-wrap" data-action="pull_create_progress" aria-label="{{label}}" bindtap="onTapCapsule">
      <canvas class="capsule-canvas" canvas-id="capsuleProgress"></canvas>
      <view class="capsule-inner">
        <view class="capsule-plus">＋</view>
        <view class="capsule-label">{{label}}</view>
      </view>
    </view>
  </view>

  <view
    class="pull-sheet {{isReturning ? 'returning' : ''}}"
    style="margin-top: {{heroHeight}}px; height: calc(100vh - {{heroHeight}}px); transform: translateY({{sheetOffsetY}}px);"
  >
    <view
      class="sheet-head-wrap"
      bindtouchstart="onSheetHeadTouchStart"
      catchtouchmove="onSheetHeadTouchMove"
      bindtouchend="onSheetHeadTouchEnd"
      bindtouchcancel="onSheetHeadTouchEnd"
    >
      <slot name="sheet-head"></slot>
    </view>
    <view class="sheet-body-wrap">
      <slot></slot>
      <view
        wx:if="{{bodyPullEnabled}}"
        class="sheet-body-touch-layer"
        bindtouchstart="onBodyTouchStart"
        catchtouchmove="onBodyTouchMove"
        bindtouchend="onBodyTouchEnd"
        bindtouchcancel="onBodyTouchEnd"
      ></view>
    </view>
  </view>
</view>
