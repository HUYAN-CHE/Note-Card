.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12rpx);
  border-bottom: 1rpx solid rgba(22, 33, 22, 0.06);
}

.custom-nav-green {
  background: rgba(212, 248, 224, 0.96);
  border-bottom: none;
}

.custom-nav-light {
  background: transparent;
  backdrop-filter: none;
  border-bottom: none;
}

.custom-nav-light .nav-title {
  color: #162116;
}

.custom-nav-light .nav-back {
  width: 56rpx;
  height: 56rpx;
  margin-left: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 78, 0.18);
}

.status-bar {
  width: 100%;
}

.nav-inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* 底部补 12px：抵消 getNavInfo 高度公式多算的 12px，使居中内容与小程序胶囊同中线 */
  padding: 0 20rpx 12px;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
}

.nav-back-icon {
  width: 42rpx;
  height: 42rpx;
}

.nav-title-wrap {
  position: absolute;
  top: calc(50% - 6px);
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: 50%;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #162116;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nav-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 72rpx;
}
